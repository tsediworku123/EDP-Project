<UserControl x:Class="ClinicAppointmentSystem.Views.MyAppointments"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClinicAppointmentSystem.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ClinicAppointmentSystem.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1200"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.DataContext>
        <vm:MyAppointmentsViewModel />
    </UserControl.DataContext>

    <!-- DialogHost for Rating Popup -->
    <materialDesign:DialogHost IsOpen="{Binding IsRatingOpen}" CloseOnClickAway="True">
        <materialDesign:DialogHost.DialogContent>
            <materialDesign:Card UniformCornerRadius="12" Padding="40" materialDesign:ElevationAssist.Elevation="Dp5" Width="500">
                <StackPanel>
                    <TextBlock Text="RATE YOUR VISIT" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text="How was your clinical experience with this session?" Opacity="0.6" Margin="0,10,0,30" />

                    <materialDesign:RatingBar Value="{Binding RatingValue}" Margin="0,0,0,30" HorizontalAlignment="Center" x:Name="RatingBar" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                    
                    <TextBox Text="{Binding RatingComment}" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             materialDesign:HintAssist.Hint="Optional: Share more feedback..." 
                             AcceptsReturn="True" TextWrapping="Wrap" Height="120" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                        <Button Content="CANCEL" Command="{Binding CloseRatingCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,15,0" />
                        <Button Content="SUBMIT FEEDBACK" Command="{Binding SubmitFeedbackCommand}" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="22" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </materialDesign:DialogHost.DialogContent>

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Search -->
                <RowDefinition Height="*" />    <!-- Tabs & Content -->
            </Grid.RowDefinitions>

            <!-- 1. HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="MY APPOINTMENTS" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <TextBlock Text="Track and manage your upcoming and past clinic visits." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Opacity="0.6" Margin="0,8,0,0" />
            </StackPanel>

            <!-- 2. SEARCH & FILTER -->
            <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="20,10" Margin="0,0,0,30" materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Search by Physician Name..." 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    <materialDesign:PackIcon Grid.Column="1" Kind="Filter" VerticalAlignment="Bottom" Margin="15,0,0,5" Opacity="0.5" />
                </Grid>
            </materialDesign:Card>

            <!-- 3. TABS & LISTS -->
            <TabControl Grid.Row="2" materialDesign:NavigationRailAssist.ShowSelectionBackground="True">
                <TabItem Header="UPCOMING">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                        <ItemsControl ItemsSource="{Binding UpcomingAppointments}" Margin="0,0,20,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card UniformCornerRadius="12" Margin="0,0,0,20" Padding="30" materialDesign:ElevationAssist.Elevation="Dp2" Background="#E8F5E9">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,40,0">
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat='MMM'}" FontWeight="Bold" Opacity="0.6" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat='dd'}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" HorizontalAlignment="Center" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat='HH:mm tt'}" FontWeight="SemiBold" Opacity="0.7" />
                                                <TextBlock Text="{Binding DoctorId, StringFormat='Dr. ID: {0}'}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" Margin="0,5,0,2" />
                                                <TextBlock Text="Confirmed Schedule" Style="{StaticResource MaterialDesignOverlineTextBlock}" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <Button Content="CANCEL" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource MaterialDesignSecondaryBody}" />
                                                <Button Content="DETAILS" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="18" Padding="15,0" />
                                            </StackPanel>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="PAST VISITS">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                        <ItemsControl ItemsSource="{Binding PastAppointments}" Margin="0,0,20,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card UniformCornerRadius="12" Margin="0,0,0,20" Padding="25" materialDesign:ElevationAssist.Elevation="Dp2" Opacity="0.9">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="{DynamicResource MaterialDesignDivider}" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,30,0" />
                                            
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat='dd MMM yyyy'}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Diagnosis}" Style="{StaticResource MaterialDesignBody1TextBlock}" Margin="0,5,0,0" Opacity="0.7" />
                                                
                                                <!-- Rating status indicator -->
                                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PatientRating}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <materialDesign:RatingBar Value="{Binding PatientRating}" IsReadOnly="True" />
                                                    <TextBlock Text="Feedback Shared" Style="{StaticResource MaterialDesignOverlineTextBlock}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- RATE Button -->
                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.RateVisitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Content="RATE VISIT" 
                                                    Style="{StaticResource MaterialDesignRaisedButton}" 
                                                    Padding="15,0" Height="35"
                                                    materialDesign:ButtonAssist.CornerRadius="18">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PatientRating}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PatientRating}" Value="1"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding PatientRating}" Value="2"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding PatientRating}" Value="3"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding PatientRating}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                            <DataTrigger Binding="{Binding PatientRating}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="CANCELLED">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                        <ItemsControl ItemsSource="{Binding CancelledAppointments}" Margin="0,0,20,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card UniformCornerRadius="12" Margin="0,0,0,20" Padding="25" Background="#FFEBEE">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat='dd MMM yyyy | hh:mm tt'}" FontWeight="Bold" Foreground="#C62828" />
                                                <TextBlock Text="Appointment was cancelled." Opacity="0.6" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <materialDesign:PackIcon Grid.Column="1" Kind="Cancel" Foreground="#C62828" VerticalAlignment="Center" />
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
