<UserControl x:Class="ClinicAppointmentSystem.Views.PatientDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClinicAppointmentSystem.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ClinicAppointmentSystem.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1200"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="{DynamicResource MaterialDesignPaper}">
    
    <UserControl.DataContext>
        <vm:PatientDashboardViewModel />
    </UserControl.DataContext>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Hero Row -->
            <RowDefinition Height="Auto" /> <!-- Stats Row -->
            <RowDefinition Height="*" />    <!-- Activity & Footer -->
        </Grid.RowDefinitions>

        <!-- 1. GREETING -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="{Binding WelcomeMessage}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
            <TextBlock Text="Manage your health and clinical schedule from a single portal." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Opacity="0.6" Margin="0,8,0,0" />
        </StackPanel>

        <!-- 2. HERO CARD (Next Appointment) -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="0" Margin="0,0,0,40" materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid Height="220">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Background Decoration -->
                <Border Grid.ColumnSpan="2" Background="{DynamicResource PrimaryHueMidBrush}" Opacity="0.05" />
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="40,0">
                    <TextBlock Text="YOUR NEXT APPOINTMENT" Style="{StaticResource MaterialDesignOverlineTextBlock}" Foreground="{DynamicResource SecondaryHueMidBrush}" FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <materialDesign:PackIcon Kind="CalendarClock" Width="35" Height="35" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0,0,15,0" />
                        <TextBlock Text="{Binding NextAppointment.AppointmentDate, StringFormat='MMMM dd, yyyy | hh:mm tt', TargetNullValue='No upcoming visits booked.'}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding NextAppointment.Reason, TargetNullValue='Stay proactive by scheduling a regular checkup.'}" Style="{StaticResource MaterialDesignBody1TextBlock}" Margin="0,10,0,0" Opacity="0.8" FontStyle="Italic" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="25" Height="50" Content="+ BOOK NEW VISIT" HorizontalAlignment="Center" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- 3. STATS TILES -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,40">
            <!-- Visits -->
            <materialDesign:Card UniformCornerRadius="12" Margin="0,0,20,0" Padding="25" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AccountCheck" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text="{Binding TotalVisits}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,10,0,5" />
                    <TextBlock Text="Total Visits" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Upcoming -->
            <materialDesign:Card UniformCornerRadius="12" Margin="10,0,10,0" Padding="25" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <materialDesign:PackIcon Kind="CalendarStar" Width="28" Height="28" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                    <TextBlock Text="{Binding UpcomingCount}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,10,0,5" />
                    <TextBlock Text="Upcoming Appointments" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Medical Records -->
            <materialDesign:Card UniformCornerRadius="12" Margin="20,0,0,0" Padding="25" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="28" Height="28" Foreground="#455A64" />
                    <TextBlock Text="{Binding MedicalRecordsCount}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,10,0,5" />
                    <TextBlock Text="Medical Records" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <!-- 4. RECENT ACTIVITY -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" UniformCornerRadius="12" Padding="30" Margin="0,0,30,0" materialDesign:ElevationAssist.Elevation="Dp2" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="RECENT CLINICAL ACTIVITY" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,20" />
                    <ItemsControl ItemsSource="{Binding RecentActivity}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="History" Margin="0,0,20,0" VerticalAlignment="Center" Opacity="0.7" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Summary}" Opacity="0.7" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Date, StringFormat='dd MMM yyyy'}" Style="{StaticResource MaterialDesignOverlineTextBlock}" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="VIEW ALL RECORDS" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Left" Margin="0,10,0,0" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Quick Access sidebar -->
            <StackPanel Grid.Column="1">
                <materialDesign:Card UniformCornerRadius="12" Padding="25" Background="{DynamicResource PrimaryHueMidBrush}" Foreground="White" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="QUICK ACCESS" FontWeight="Bold" Opacity="0.8" />
                        <Button Content="Personal Profile" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" Margin="0,20,0,0" />
                        <Button Content="Rate My Physicians" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" />
                        <Button Content="Help &amp; Support" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" HorizontalAlignment="Left" />
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
