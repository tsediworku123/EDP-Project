<UserControl x:Class="ClinicAppointmentSystem.Views.MyProfile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClinicAppointmentSystem.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ClinicAppointmentSystem.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1200"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.DataContext>
        <vm:PatientProfileViewModel />
    </UserControl.DataContext>

    <Grid Margin="60,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- Profile Form -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,40">
            <TextBlock Text="MY PROFILE" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
            <TextBlock Text="Manage your personal information and clinical profile details." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Opacity="0.6" Margin="0,8,0,0" />
        </StackPanel>

        <!-- 2. FORM GRID -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: PERSONAL INFO -->
            <StackPanel Grid.Column="0" Margin="0,0,30,0">
                <materialDesign:Card UniformCornerRadius="12" Padding="40" materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="PERSONAL DETAILS" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,30" />
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <materialDesign:PackIcon Kind="Account" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <TextBox Text="{Binding Patient.FullName}" materialDesign:HintAssist.Hint="Full Name" Header="FULL NAME" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Width="300" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <materialDesign:PackIcon Kind="Calendar" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <DatePicker SelectedDate="{Binding Patient.DateOfBirth}" materialDesign:HintAssist.Hint="Date of Birth" Header="DATE OF BIRTH" Width="300" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <materialDesign:PackIcon Kind="GenderMaleFemale" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <ComboBox Text="{Binding Patient.Gender}" materialDesign:HintAssist.Hint="Gender" Header="GENDER" Width="300">
                                <ComboBoxItem Content="Male" />
                                <ComboBoxItem Content="Female" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MapMarker" Width="24" Height="24" Opacity="0.5" VerticalContentAlignment="Top" Margin="0,5,20,0" />
                            <TextBox Text="{Binding Patient.Address}" materialDesign:HintAssist.Hint="Residential Address" Header="RESIDENTIAL ADDRESS" 
                                     AcceptsReturn="True" TextWrapping="Wrap" Width="300" Height="80" VerticalContentAlignment="Top" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- CONTACT INFO -->
                <materialDesign:Card UniformCornerRadius="12" Padding="40" Margin="0,30,0,0" materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="CONTACT CHANNELS" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,30" />
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <materialDesign:PackIcon Kind="Phone" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <TextBox Text="{Binding Patient.Phone}" materialDesign:HintAssist.Hint="Phone Number" Header="PHONE" Width="300" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Email" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <TextBox Text="{Binding Patient.Email}" materialDesign:HintAssist.Hint="Email Address" Header="EMAIL" Width="300" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <!-- RIGHT: MEDICAL & EMERGENCY -->
            <StackPanel Grid.Column="1" Margin="30,0,0,0">
                <materialDesign:Card UniformCornerRadius="12" Padding="40" materialDesign:ElevationAssist.Elevation="Dp2" Background="#FFF8E1">
                    <StackPanel>
                        <TextBlock Text="EMERGENCY CONTACT" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,30" />
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                            <materialDesign:PackIcon Kind="AccountAlert" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <TextBox Text="{Binding Patient.EmergencyContactName}" materialDesign:HintAssist.Hint="Contact Person" Header="NAME" Width="300" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PhoneAlert" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,20,0" />
                            <TextBox Text="{Binding Patient.EmergencyContactPhone}" materialDesign:HintAssist.Hint="Contact Phone" Header="PHONE" Width="300" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card UniformCornerRadius="12" Padding="40" Margin="0,30,0,0" materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="CLINICAL NOTES" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,30" />
                        
                        <TextBox Text="{Binding Patient.AllergiesOrChronicConditions}" materialDesign:HintAssist.Hint="Allergies or Chronic Conditions" Header="ALLERGIES" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,25" />
                        
                        <TextBox Text="{Binding Patient.MedicalNotes}" materialDesign:HintAssist.Hint="Additional Medical Notes" Header="NOTES" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="150" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>
                </materialDesign:Card>

                <Button Content="SAVE PROFILE CHANGES" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Height="55" Margin="0,40,0,0" materialDesign:ButtonAssist.CornerRadius="28" FontWeight="Bold" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
