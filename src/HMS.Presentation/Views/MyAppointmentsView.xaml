<UserControl x:Class="HMS.Core.Views.MyAppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1200"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:MyAppointmentsViewModel />
    </UserControl.DataContext>

    <Grid Margin="60,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Search area -->
            <RowDefinition Height="*" />    <!-- Tabs & Content area -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER SECTION -->
        <StackPanel Grid.Row="0" Margin="0,0,0,45">
            <TextBlock Text="MY APPOINTMENTS" 
                       Style="{StaticResource MaterialDesignHeadline3TextBlock}" 
                       FontWeight="Bold" Foreground="#2196F3" />
            <TextBlock Text="Effortlessly manage your scheduled visits and review your complete clinical history." 
                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                       Opacity="0.6" Margin="4,12,0,0" />
        </StackPanel>

        <!-- 2. SEARCH & FILTER INTEGRATION -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="15" Padding="30,15" Margin="0,0,0,45" 
                             materialDesign:ElevationAssist.Elevation="Dp1" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Filter by Physician Name or Specialty..." 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         FontSize="15" BorderThickness="0" />
                <materialDesign:PackIcon Grid.Column="1" Kind="Magnify" Width="24" Height="24" 
                                         VerticalAlignment="Center" Margin="15,0,0,0" Opacity="0.4" />
            </Grid>
        </materialDesign:Card>

        <!-- 3. TABS & APPOINTMENT CARDS -->
        <TabControl Grid.Row="2" materialDesign:NavigationRailAssist.ShowSelectionBackground="True" 
                    Background="Transparent" BorderThickness="0">
            
            <!-- UPCOMING APPOINTMENTS -->
            <TabItem Header="UPCOMING SESSIONS">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,30,0,0">
                    <ItemsControl ItemsSource="{Binding UpcomingAppointments}" Margin="0,10,15,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card UniformCornerRadius="15" Margin="0,0,0,30" Padding="0" 
                                                     materialDesign:ElevationAssist.Elevation="Dp3" Background="White">
                                    <Grid Height="140">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- DATE ACCENT STRIP -->
                                        <Border Grid.Column="0" Background="#2196F3" Width="120" Padding="15">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat='MMM'}" 
                                                           Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" FontSize="14" Opacity="0.9" />
                                                <TextBlock Text="{Binding AppointmentDate, StringFormat='dd'}" 
                                                           Style="{StaticResource MaterialDesignHeadline3TextBlock}" 
                                                           Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-4" />
                                            </StackPanel>
                                        </Border>

                                        <!-- DETAILS -->
                                        <Grid Grid.Column="1" Margin="40,0">
                                            <StackPanel VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <materialDesign:PackIcon Kind="ClockTimeFiveOutline" Width="20" Height="20" 
                                                                             Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                    <TextBlock Text="{Binding AppointmentDate, StringFormat='hh:mm tt'}" 
                                                               FontSize="15" FontWeight="SemiBold" Foreground="#1A237E" VerticalAlignment="Center" />
                                                </StackPanel>
                                                
                                                <TextBlock Text="{Binding DoctorName, TargetNullValue='Alpha Clinic Physician'}" 
                                                           Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                                                           FontWeight="Bold" Foreground="#37474F" />
                                                
                                                <Border Background="#E8F5E9" HorizontalAlignment="Left" CornerRadius="10" Padding="12,4" Margin="0,10,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16" Foreground="#2E7D32" 
                                                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBlock Text="CONFIRMED APPOINTMENT" Foreground="#2E7D32" 
                                                                   FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- ACTIONS -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,40,0" Orientation="Horizontal">
                                            <Button Content="CANCEL" Style="{StaticResource MaterialDesignFlatButton}" 
                                                    Foreground="#D32F2F" FontWeight="Bold" Margin="0,0,20,0" />
                                            <Button Content="VIEW DETAILS" Style="{StaticResource MaterialDesignRaisedButton}" 
                                                    materialDesign:ButtonAssist.CornerRadius="22" Height="44" Padding="30,0" 
                                                    Background="#2196F3" BorderBrush="#2196F3" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- PAST VISITS -->
            <TabItem Header="PAST VISITS">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,30,0,0">
                    <ItemsControl ItemsSource="{Binding PastAppointments}" Margin="0,10,15,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card UniformCornerRadius="12" Margin="0,0,0,20" Padding="30" 
                                                     Opacity="0.85" materialDesign:ElevationAssist.Elevation="Dp1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <materialDesign:PackIcon Kind="CalendarCheckOutline" Foreground="#607D8B" 
                                                                 Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,30,0" />
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AppointmentDate, StringFormat='dddd, MMMM dd, yyyy'}" 
                                                       FontWeight="Bold" Foreground="#37474F" FontSize="16" />
                                            <TextBlock Text="{Binding Reason, TargetNullValue='General Consultation'}" 
                                                       Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                                       Margin="0,8,0,0" Opacity="0.6" FontStyle="Italic" />
                                        </StackPanel>

                                        <Border Grid.Column="2" Background="#F1F1F1" CornerRadius="12" Padding="15,6" VerticalAlignment="Center">
                                            <TextBlock Text="COMPLETED" FontWeight="Bold" Foreground="#9E9E9E" FontSize="12" />
                                        </Border>
                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- CANCELLED APPOINTMENTS -->
            <TabItem Header="CANCELLED">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,30,0,0">
                    <ItemsControl ItemsSource="{Binding CancelledAppointments}" Margin="0,10,15,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card UniformCornerRadius="12" Margin="0,0,0,20" Padding="25" 
                                                     Background="#FFF5F5" materialDesign:ElevationAssist.Elevation="Dp1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <materialDesign:PackIcon Kind="CalendarRemove" Foreground="#C62828" 
                                                                 Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,25,0" />
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AppointmentDate, StringFormat='dd MMM yyyy | hh:mm tt'}" 
                                                       FontWeight="Bold" Foreground="#C62828" />
                                            <TextBlock Text="Patient scheduled visit was cancelled." Opacity="0.5" Margin="0,4,0,0" />
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2" Content="REBOOK VISIT" Style="{StaticResource MaterialDesignFlatButton}" 
                                                Foreground="#2196F3" FontWeight="Bold" VerticalAlignment="Center" />
                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
