<UserControl x:Class="HMS.Core.Views.AdminReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F8FAFC">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Quick Stats -->
            <RowDefinition Height="Auto" /> <!-- Filters -->
            <RowDefinition Height="*" />    <!-- Report Modules -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="REPORTS &amp; DATA EXPORT" FontSize="26" FontWeight="Bold" Foreground="#1E293B" />
            <TextBlock Text="Analyze clinical performance, patient growth, and financial summaries through detailed exports." 
                       Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Quick Stats Banner -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Total Patients Card -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,12,0" Padding="15" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <TextBlock Text="Total Patients" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalPatients}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Total Doctors Card -->
            <materialDesign:Card Grid.Column="1" Margin="6,0,6,0" Padding="15" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <TextBlock Text="Total Doctors" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalDoctors}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Completed Visits Card -->
            <materialDesign:Card Grid.Column="2" Margin="6,0,6,0" Padding="15" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <TextBlock Text="Completed Visits" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CompletedAppointments}" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Total Revenue Card -->
            <materialDesign:Card Grid.Column="3" Margin="12,0,0,0" Padding="15" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <TextBlock Text="Clinical Revenue" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalRevenue}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Global Filters Bar -->
        <materialDesign:Card Grid.Row="2" Margin="0,0,0,25" UniformCornerRadius="12" Padding="20,15" materialDesign:ElevationAssist.Elevation="Dp2" Background="#1E293B">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="CalendarMonth" Foreground="White" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="EXPORT TIME RANGE:" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,20,0"/>
                
                <Border Background="White" CornerRadius="8" Padding="15,2,15,5" Margin="0,0,12,0">
                    <DatePicker materialDesign:HintAssist.Hint="Start Date" 
                                SelectedDate="{Binding StartDate}" 
                                Foreground="#1E293B" BorderBrush="Transparent" 
                                Width="130" 
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
                </Border>
                
                <Border Background="White" CornerRadius="8" Padding="15,2,15,5" Margin="0,0,20,0">
                    <DatePicker materialDesign:HintAssist.Hint="End Date" 
                                SelectedDate="{Binding EndDate}" 
                                Foreground="#1E293B" BorderBrush="Transparent" 
                                Width="130" 
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
                </Border>

                <Button Command="{Binding RefreshStatsCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#3B82F6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="RE-SYNC DATA" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <!-- Report Modules -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Patient Demographics Module -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,15,0" UniformCornerRadius="16" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#EFF6FF" Height="140" CornerRadius="16,16,0,0">
                        <materialDesign:PackIcon Kind="AccountMultiple" Width="60" Height="60" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="25">
                        <TextBlock Text="PATIENT DIRECTORY" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Full demographic audit including contact info, gender distribution, and registration timelines." 
                                   TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#64748B" LineHeight="20"/>
                    </StackPanel>
                    
                    <Button Grid.Row="2" Command="{Binding ExportPatientsCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="#3B82F6" BorderThickness="0" Margin="25,0,25,25" Height="45"
                            materialDesign:ButtonAssist.CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDownload" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="EXPORT PATIENT CSV" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <!-- Clinical Log Module -->
            <materialDesign:Card Grid.Column="1" Margin="7,0,7,0" UniformCornerRadius="16" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#F0FDF4" Height="140" CornerRadius="16,16,0,0">
                        <materialDesign:PackIcon Kind="CalendarClock" Width="60" Height="60" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="25">
                        <TextBlock Text="APPOINTMENT AUDIT" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Comprehensive log of all medical interactions, including consultation reasons and appointment statuses." 
                                   TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#64748B" LineHeight="20"/>
                    </StackPanel>
                    
                    <Button Grid.Row="2" Command="{Binding ExportAppointmentsCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="#10B981" BorderThickness="0" Margin="25,0,25,25" Height="45"
                            materialDesign:ButtonAssist.CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="GENERATE ACTIVITY CSV" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <!-- Financial Summary Module -->
            <materialDesign:Card Grid.Column="2" Margin="15,0,0,0" UniformCornerRadius="16" Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#FFF7ED" Height="140" CornerRadius="16,16,0,0">
                        <materialDesign:PackIcon Kind="CurrencyUsd" Width="60" Height="60" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="25">
                        <TextBlock Text="REVENUE RECONCILIATION" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Summary of all billed services, total revenue collected, and pending payments for the selected period." 
                                   TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#64748B" LineHeight="20"/>
                    </StackPanel>
                    
                    <Button Grid.Row="2" Command="{Binding ExportFinancialCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="#F59E0B" BorderThickness="0" Margin="25,0,25,25" Height="45"
                            materialDesign:ButtonAssist.CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Finance" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="FINANCIAL EXPORT" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>

