<UserControl x:Class="HMS.Core.Views.AdminUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F8FAFC">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Stats -->
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="*" />    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="USER ACCOUNT CONTROL" FontSize="24" FontWeight="Bold" Foreground="#1E293B" />
            <TextBlock Text="Manage system access, roles, and security credentials for all staff and patients." Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Stats Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Total Users -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,12,0" Padding="20" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="24" Background="#EFF6FF">
                        <materialDesign:PackIcon Kind="AccountGroup" Foreground="#3B82F6" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalUsers}" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Total Accounts" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Active Staff -->
            <materialDesign:Card Grid.Column="1" Margin="6,0,6,0" Padding="20" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="24" Background="#F0FDF4">
                        <materialDesign:PackIcon Kind="ShieldCheck" Foreground="#22C55E" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveStaff}" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Active Staff" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Deactivated -->
            <materialDesign:Card Grid.Column="2" Margin="12,0,0,0" Padding="20" UniformCornerRadius="12" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="24" Background="#FEF2F2">
                        <materialDesign:PackIcon Kind="AccountOff" Foreground="#EF4444" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DeactivatedUsers}" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Blocked/Inactive" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Filters Toolbar -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20,15" Margin="0,0,0,20" materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <materialDesign:ColorZone Grid.Column="0" Mode="Standard" CornerRadius="8" Padding="12,4" materialDesign:ElevationAssist.Elevation="Dp0" Background="#F1F5F9" Margin="0,0,15,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Search" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search by username or email..." BorderThickness="0" Background="Transparent" VerticalAlignment="Center"/>
                    </Grid>
                </materialDesign:ColorZone>

                <!-- Role Filter -->
                <ComboBox Grid.Column="1" ItemsSource="{Binding RoleOptions}" SelectedValue="{Binding SelectedRole}" materialDesign:HintAssist.Hint="Account Type" Width="180" Margin="0,0,15,0" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <!-- Refresh -->
                <Button Grid.Column="2" Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}" Background="#3B82F6" BorderThickness="0" Margin="0,0,10,0">
                    <materialDesign:PackIcon Kind="Refresh" />
                </Button>

                <!-- Add User -->
                <Button Grid.Column="3" Click="AddUser_Click" Style="{StaticResource MaterialDesignRaisedButton}" Background="#3B82F6" materialDesign:ButtonAssist.CornerRadius="8" Height="40">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="NEW ACCOUNT" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <materialDesign:Card Grid.Row="3" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2" Background="White">
            <DataGrid ItemsSource="{Binding FilteredUsers}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" CanUserAddRows="False" GridLinesVisibility="None" SelectionMode="Single">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Height" Value="45"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="15,0"/>
                    </Style>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="Height" Value="60"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- User Column -->
                    <DataGridTemplateColumn Header="USER IDENTIFIER" Width="250">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <Border Width="36" Height="36" CornerRadius="18" Background="#F1F5F9">
                                        <materialDesign:PackIcon Kind="Account" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Username}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding Email}" FontSize="11" Foreground="#64748B"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Role Column -->
                    <DataGridTemplateColumn Header="ACCESS ROLE" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" Background="#EFF6FF" Margin="15,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ShieldAccount" Foreground="#3B82F6" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="Bold" Foreground="#1E40AF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status Column -->
                    <DataGridTemplateColumn Header="ACCOUNT STATUS" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsActive, Mode=OneWay}" 
                                                  Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  CommandParameter="{Binding}">
                                        <ToggleButton.LayoutTransform>
                                            <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                        </ToggleButton.LayoutTransform>
                                    </ToggleButton>
                                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Inactive"/>
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Text" Value="Active"/>
                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actions Column -->
                    <DataGridTemplateColumn Header="SECURITY ACTIONS" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                                    <Button Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" 
                                            Style="{StaticResource MaterialDesignIconButton}" 
                                            ToolTip="Reset Password to Default" 
                                            Foreground="#F59E0B">
                                        <materialDesign:PackIcon Kind="LockReset" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Edit Permissions" Foreground="#64748B">
                                        <materialDesign:PackIcon Kind="ShieldEdit" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>

