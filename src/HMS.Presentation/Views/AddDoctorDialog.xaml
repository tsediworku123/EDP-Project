<UserControl x:Class="HMS.Core.Views.AddDoctorDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="500" Padding="30">
    <StackPanel>
        <TextBlock Text="{Binding DialogTitle}" Style="{DynamicResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" Margin="0,0,0,25" HorizontalAlignment="Center" Foreground="#1E293B"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,15" materialDesign:HintAssist.Hint="Full Name" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />
            
            <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Specialization" ItemsSource="{Binding Specialties}" SelectedItem="{Binding Specialty}" Style="{DynamicResource MaterialDesignOutlinedComboBox}" />

            <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,15" materialDesign:HintAssist.Hint="Phone Number" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />
            
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Email Address" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />

            <ComboBox Grid.Row="2" Grid.Column="0" Margin="0,0,10,15" materialDesign:HintAssist.Hint="Department" ItemsSource="{Binding Departments}" SelectedItem="{Binding Department}" Style="{DynamicResource MaterialDesignOutlinedComboBox}" />
            
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Shift" SelectedItem="{Binding AssignedShift}" Style="{DynamicResource MaterialDesignOutlinedComboBox}">
                <ComboBoxItem Content="Morning" />
                <ComboBoxItem Content="Afternoon" />
                <ComboBoxItem Content="Night" />
            </ComboBox>

            <TextBox Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Office Address" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="CANCEL" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{DynamicResource MaterialDesignFlatButton}" Margin="0,0,10,0" Foreground="#64748B"/>
            <Button Content="{Binding ActionButtonText}" Command="{Binding SaveCommand}" Style="{DynamicResource MaterialDesignFlatMidPrimaryButton}" Background="#3B82F6" Width="180" />
        </StackPanel>
    </StackPanel>
</UserControl>
