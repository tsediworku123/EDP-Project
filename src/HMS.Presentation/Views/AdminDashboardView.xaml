<UserControl x:Class="HMS.Core.Views.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="ADMINISTRATIVE OVERVIEW" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="#1E293B" />
            <TextBlock Text="Monitor system health, manage staff, and view hospital analytics." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Opacity="0.6" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="4" VerticalAlignment="Top">
            <materialDesign:Card Style="{StaticResource PremiumCard}" Margin="0,0,15,0" Background="#F1F5F9">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Doctor" Foreground="#3B82F6" Width="32" Height="32" />
                    <TextBlock Text="{Binding TotalDoctors}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,15,0,0" />
                    <TextBlock Text="Active Doctors" Opacity="0.5" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Style="{StaticResource PremiumCard}" Margin="0,0,15,0" Background="#F0F9FF">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AccountGroup" Foreground="#0EA5E9" Width="32" Height="32" />
                    <TextBlock Text="{Binding TotalPatients}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,15,0,0" />
                    <TextBlock Text="Registered Patients" Opacity="0.5" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Style="{StaticResource PremiumCard}" Margin="0,0,15,0" Background="#ECFDF5">
                <StackPanel>
                    <materialDesign:PackIcon Kind="CalendarCheck" Foreground="#10B981" Width="32" Height="32" />
                    <TextBlock Text="{Binding TotalAppointments}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,15,0,0" />
                    <TextBlock Text="Total Appointments" Opacity="0.5" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Style="{StaticResource PremiumCard}" Background="#FFF7ED">
                <StackPanel>
                    <materialDesign:PackIcon Kind="CashMultiple" Foreground="#F59E0B" Width="32" Height="32" />
                    <TextBlock Text="$42,500" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,15,0,0" />
                    <TextBlock Text="Monthly Revenue" Opacity="0.5" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>
    </Grid>
</UserControl>
