<UserControl x:Class="HMS.Core.Views.AdminDoctorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F8FAFC">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel>
                <TextBlock Text="DOCTOR MANAGEMENT" Style="{DynamicResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="#1E293B" />
                <TextBlock Text="Manage medical staff, specialties, and clinical availability settings." Style="{DynamicResource MaterialDesignSubtitle1TextBlock}" Opacity="0.6" />
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="REFRESH" Command="{Binding RefreshCommand}" Style="{DynamicResource MaterialDesignOutlinedButton}" Margin="0,0,10,0" BorderBrush="#CBD5E1" Foreground="#64748B"/>
                <Button Command="{Binding AddDoctorCommand}" Style="{DynamicResource MaterialDesignFlatMidPrimaryButton}" Background="#3B82F6" BorderThickness="0" Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ADD NEW DOCTOR" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Stats & Search Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <!-- Mini Stats Indicators -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Background="White" CornerRadius="8" Padding="15,10" Margin="0,0,15,0" materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountCheck" Foreground="#10B981" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="Active:" Foreground="#64748B" FontSize="11"/>
                            <Run Text="{Binding TotalActiveDoctors, Mode=OneWay}" FontWeight="Bold" FontSize="13"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Padding="15,10" materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Stethoscope" Foreground="#6366F1" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="Specialties:" Foreground="#64748B" FontSize="11"/>
                            <Run Text="{Binding TotalSpecialties, Mode=OneWay}" FontWeight="Bold" FontSize="13"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- SearchBox -->
            <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="15,0" materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="Search" VerticalAlignment="Center" Foreground="#94A3B8" Width="18" Height="18"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" 
                             BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0" 
                             materialDesign:HintAssist.Hint="Search by name or specialty..." />
                </Grid>
            </Border>
        </Grid>

        <!-- Main DataGrid -->
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="15" materialDesign:ElevationAssist.Elevation="Dp1">
            <DataGrid ItemsSource="{Binding Doctors}" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" SelectionMode="Single" Background="Transparent" 
                      BorderThickness="0" HeadersVisibility="Column" GridLinesVisibility="None">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Height" Value="50"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="Height" Value="60"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                
                <DataGrid.Columns>
                    <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*"/>
                    
                    <DataGridTemplateColumn Header="SPECIALIZATION" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#EEF2FF" CornerRadius="12" Padding="12,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Specialization}" Foreground="#4F46E5" FontWeight="SemiBold" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="PHONE" Binding="{Binding PhoneNumber}" Width="160"/>
                    <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*"/>
                    
                    <DataGridTemplateColumn Header="STATUS" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="10" Height="10" ToolTip="Active">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#10B981"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Fill" Value="#EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACTIONS" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.EditDoctorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" 
                                            Style="{DynamicResource MaterialDesignIconButton}" Width="32" Height="32" Padding="0" ToolTip="Edit">
                                        <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" Foreground="#64748B"/>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteDoctorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" 
                                            Style="{DynamicResource MaterialDesignIconButton}" Width="32" Height="32" Padding="0" ToolTip="Delete">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Foreground="#EF4444"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
