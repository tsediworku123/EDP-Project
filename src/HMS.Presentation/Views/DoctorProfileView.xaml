<UserControl x:Class="HMS.Core.Views.DoctorProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1100"
             Background="#F0F4F8">

    <UserControl.DataContext>
        <vm:DoctorProfileViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="SectionCard" TargetType="materialDesign:Card">
            <Setter Property="UniformCornerRadius" Value="20"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="14"/>
        </Style>

        <Style x:Key="PwdBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="14"/>
        </Style>

        <Style x:Key="StatusBannerSuccess" TargetType="Border">
            <Setter Property="Background" Value="#DCFCE7"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>
        <Style x:Key="StatusBannerError" TargetType="Border">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,36,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- PAGE HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <TextBlock Text="MY PROFILE"
                           FontSize="28" FontWeight="Black" Foreground="#1E293B"/>
                <TextBlock Text="Manage your account information, photo, and security settings."
                           FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: AVATAR CARD -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <materialDesign:Card Style="{StaticResource SectionCard}">
                        <StackPanel HorizontalAlignment="Center">

                            <!-- Avatar -->
                            <Grid Width="140" Height="140" HorizontalAlignment="Center" Margin="0,0,0,18">
                                <!-- Gradient background always shown -->
                                <Ellipse Width="140" Height="140">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1E3A8A" Offset="0"/>
                                            <GradientStop Color="#3B82F6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <!-- Initials shown when no photo -->
                                <TextBlock Text="{Binding DoctorInitials}"
                                           FontSize="46" FontWeight="Black"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Photo overlay when available -->
                                <Ellipse Width="140" Height="140">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding ProfilePhoto}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <!-- Camera badge -->
                                <Button Command="{Binding ChangePhotoCommand}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                        Background="#2563EB" BorderBrush="#2563EB"
                                        Width="36" Height="36"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        ToolTip="Change photo">
                                    <materialDesign:PackIcon Kind="Camera" Width="18" Height="18" Foreground="White"/>
                                </Button>
                            </Grid>

                            <!-- Name and role -->
                            <TextBlock Text="{Binding FullName}"
                                       FontSize="17" FontWeight="Bold"
                                       Foreground="#1E293B"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                            <TextBlock Text="{Binding DoctorRoleLabel}"
                                       FontSize="12" Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>

                            <!-- Change photo button -->
                            <Button Command="{Binding ChangePhotoCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,20,0,0"
                                    Height="42"
                                    materialDesign:ButtonAssist.CornerRadius="12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ImageEdit" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Change Photo" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <!-- Unsaved indicator -->
                            <Border Background="#FEF3C7" CornerRadius="10" Padding="12,8" Margin="0,16,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#D97706" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Unsaved changes" Foreground="#D97706" FontSize="12" FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>

                <!-- RIGHT: FORMS -->
                <StackPanel Grid.Column="1">

                    <!-- Profile Info Card -->
                    <materialDesign:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                <Border Width="4" Height="22" Background="#3B82F6" CornerRadius="2" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="PERSONAL INFORMATION" Style="{StaticResource SectionHeader}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Full Name -->
                                <StackPanel Grid.Column="0" Grid.Row="0">
                                    <TextBlock Text="FULL NAME" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="AccountOutline" Foreground="#3B82F6" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Dr. John Smith"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                 Margin="30,0,0,0" FontSize="14"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Phone Number -->
                                <StackPanel Grid.Column="2" Grid.Row="0">
                                    <TextBlock Text="PHONE NUMBER" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="Phone" Foreground="#10B981" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="+251 9XX XXX XXX"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                 Margin="30,0,0,0" FontSize="14"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Specialization -->
                                <StackPanel Grid.Column="0" Grid.Row="2">
                                    <TextBlock Text="SPECIALIZATION" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="Stethoscope" Foreground="#8B5CF6" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Specialization, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="e.g. Cardiology"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                 Margin="30,0,0,0" FontSize="14"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Email -->
                                <StackPanel Grid.Column="2" Grid.Row="2">
                                    <TextBlock Text="EMAIL ADDRESS" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="EmailOutline" Foreground="#F59E0B" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="doctor@alphaclinic.com"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                 Margin="30,0,0,0" FontSize="14"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Profile status messages -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#DCFCE7"/>
                                        <Setter Property="CornerRadius" Value="10"/>
                                        <Setter Property="Padding" Value="14,10"/>
                                        <Setter Property="Margin" Value="0,20,0,0"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding StatusIsError}" Value="False"/>
                                                    <Condition Binding="{Binding HasStatusMessage}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#16A34A" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="#16A34A" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FEE2E2"/>
                                        <Setter Property="CornerRadius" Value="10"/>
                                        <Setter Property="Padding" Value="14,10"/>
                                        <Setter Property="Margin" Value="0,4,0,0"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding StatusIsError}" Value="True"/>
                                                    <Condition Binding="{Binding HasStatusMessage}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="#DC2626" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Save button -->
                            <Button Command="{Binding SaveProfileCommand}"
                                    Style="{StaticResource SaveBtn}"
                                    Margin="0,20,0,0"
                                    HorizontalAlignment="Right"
                                    Width="220">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="SAVE CHANGES" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Change Password Card -->
                    <materialDesign:Card Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                <Border Width="4" Height="22" Background="#EF4444" CornerRadius="2" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="CHANGE PASSWORD" Style="{StaticResource SectionHeader}"/>
                            </StackPanel>

                            <!-- Current password row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="CURRENT PASSWORD" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="LockOutline" Foreground="#64748B" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <PasswordBox x:Name="CurrentPasswordBox"
                                                     materialDesign:HintAssist.Hint="Enter current password"
                                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                                     Margin="30,0,0,0" FontSize="14"
                                                     PasswordChanged="CurrentPasswordBox_PasswordChanged"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- New / Confirm row -->
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="NEW PASSWORD" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="LockReset" Foreground="#3B82F6" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <PasswordBox x:Name="NewPasswordBox"
                                                     materialDesign:HintAssist.Hint="Min. 6 characters"
                                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                                     Margin="30,0,0,0" FontSize="14"
                                                     PasswordChanged="NewPasswordBox_PasswordChanged"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="CONFIRM NEW PASSWORD" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <materialDesign:PackIcon Kind="LockCheck" Foreground="#10B981" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <PasswordBox x:Name="ConfirmPasswordBox"
                                                     materialDesign:HintAssist.Hint="Re-enter new password"
                                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                                     Margin="30,0,0,0" FontSize="14"
                                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Password status banners -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#DCFCE7"/>
                                        <Setter Property="CornerRadius" Value="10"/>
                                        <Setter Property="Padding" Value="14,10"/>
                                        <Setter Property="Margin" Value="0,20,0,0"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding PasswordStatusIsError}" Value="False"/>
                                                    <Condition Binding="{Binding HasPasswordStatusMessage}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#16A34A" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding PasswordStatusMessage}" Foreground="#16A34A" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FEE2E2"/>
                                        <Setter Property="CornerRadius" Value="10"/>
                                        <Setter Property="Padding" Value="14,10"/>
                                        <Setter Property="Margin" Value="0,4,0,0"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding PasswordStatusIsError}" Value="True"/>
                                                    <Condition Binding="{Binding HasPasswordStatusMessage}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="#DC2626" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding PasswordStatusMessage}" Foreground="#DC2626" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Change password button -->
                            <Button Command="{Binding ChangePasswordCommand}"
                                    Style="{StaticResource PwdBtn}"
                                    Margin="0,20,0,0"
                                    HorizontalAlignment="Right"
                                    Width="240">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldLock" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="UPDATE PASSWORD" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </materialDesign:Card>

                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
