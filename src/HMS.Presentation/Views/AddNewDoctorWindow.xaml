<Window x:Class="HMS.Core.Views.AddNewDoctorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:HMS.Core.Views"
        mc:Ignorable="d"
        Title="Add New Doctor" Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <TextBlock Text="Add New Doctor" Style="{StaticResource MaterialDesignHeadline4TextBlock}" Margin="0,0,0,16"/>
                
                <!-- Section 1: Doctor Profile -->
                <materialDesign:Card Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Doctor Profile" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,8"/>
                        
                        <TextBox materialDesign:HintAssist.Hint="Full Name *" 
                                 Text="{Binding FullName}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>
                        
                        <TextBox materialDesign:HintAssist.Hint="Specialty *" 
                                 Text="{Binding Specialty}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>
                        
                        <TextBox materialDesign:HintAssist.Hint="Phone" 
                                 Text="{Binding Phone}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Start Time (HH:mm)" 
                                     Text="{Binding WorkingHoursStart, StringFormat=hh\\:mm}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="End Time (HH:mm)" 
                                     Text="{Binding WorkingHoursEnd, StringFormat=hh\\:mm}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                        </Grid>

                        <TextBox materialDesign:HintAssist.Hint="Working Days (e.g. Mon, Tue)" 
                                 Text="{Binding WorkingDays}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>

                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Slot Duration (min)" 
                                     Text="{Binding DefaultSlotDuration}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Buffer Time (min)" 
                                     Text="{Binding BufferTime}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                        </Grid>
                        
                        <TextBox materialDesign:HintAssist.Hint="Calendar Color (Hex)" 
                                 Text="{Binding CalendarColor}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Section 2: Login Account -->
                <materialDesign:Card Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Login Account" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,8"/>
                        
                        <TextBox materialDesign:HintAssist.Hint="Username *" 
                                 Text="{Binding Username}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>
                        
                        <PasswordBox materialDesign:HintAssist.Hint="Password *" 
                                     x:Name="PassBox"
                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,8"/>
                        <!-- Note: Binding PasswordBox in MVVM usually requires an attached property or simple helper. 
                             For this demo, we'll assume the VM handles it or use the x:Name in code-behind if needed. -->

                        <PasswordBox materialDesign:HintAssist.Hint="Confirm Password *" 
                                     x:Name="ConfirmPassBox"
                                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,8"/>
                        
                        <TextBox materialDesign:HintAssist.Hint="Email (Optional)" 
                                 Text="{Binding Email}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Content="CANCEL" Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Content="SAVE DOCTOR" Click="SaveButton_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
