<UserControl x:Class="HMS.Core.Views.DoctorPrescribeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="PRESCRIBE MEDICATIONS" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="ExtraBold" Foreground="#000000" />
            <TextBlock Text="Issue electronic prescriptions directly to patients and pharmacies." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Foreground="#6B7280" Margin="0,8,0,40" />

            <materialDesign:Card UniformCornerRadius="10" Padding="30" Width="600" HorizontalAlignment="Left" Background="#F0FDF4">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Pill" Width="40" Height="40" Foreground="#16A34A" Margin="0,0,0,15"/>
                    <TextBlock Text="E-Prescribing Module" FontWeight="Bold" FontSize="18" Foreground="#14532D" />
                    <TextBlock Text="Pharmacy database connection and dosage rules applied here." Foreground="#16A34A" Margin="0,10,0,0" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</UserControl>
