<UserControl x:Class="HMS.Core.Views.DoctorPrescribeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:DoctorPrescribeViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="36,30,36,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="5" Height="32" Background="#16A34A" CornerRadius="3" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="PRESCRIBE MEDICATIONS" FontSize="26" FontWeight="Black" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Select a patient and build an electronic prescription with medicines and dosages." FontSize="13" Foreground="#64748B"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Appointment Selector -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="16" Padding="24" materialDesign:ElevationAssist.Elevation="Dp2" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="SELECT PATIENT" FontSize="11" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,14"/>
                        <ListBox ItemsSource="{Binding TodayAppointments}"
                                 SelectedItem="{Binding SelectedAppointment}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,12" CornerRadius="10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PatientName}" FontWeight="Bold" FontSize="13" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding Reason}" FontSize="11" Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <StackPanel HorizontalAlignment="Center" Margin="0,16">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoAppointments}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="CalendarBlank" Width="32" Height="32" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock Text="No appointments today" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Right: Prescription Builder -->
                <materialDesign:Card Grid.Column="2" UniformCornerRadius="16" Padding="28" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                    <!-- No selection  -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <materialDesign:PackIcon Kind="Pill" Width="56" Height="56" Foreground="#16A34A" HorizontalAlignment="Center" Opacity="0.4"/>
                        <TextBlock Text="Select a patient to write a prescription" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    </StackPanel>

                    <!-- Prescription form -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Patient header -->
                        <Border Background="#F0FDF4" CornerRadius="12" Padding="16,12" Margin="0,0,0,22">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Account" Width="22" Height="22" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedPatientName}" FontSize="15" FontWeight="Bold" Foreground="#14532D"/>
                                    <TextBlock Text="{Binding SelectedAppointmentInfo}" FontSize="11" Foreground="#16A34A"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Add Medicine -->
                        <TextBlock Text="ADD MEDICINE" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding MedicineName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Medicine name (e.g. Amoxicillin)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <TextBox Grid.Column="2" Text="{Binding Dosage, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Dosage (e.g. 500mg)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <ComboBox Grid.Column="4" ItemsSource="{Binding FrequencyOptions}"
                                      SelectedItem="{Binding Frequency}"
                                      materialDesign:HintAssist.Hint="Frequency"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Instructions, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Special instructions (e.g. Take after meals)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <TextBlock Grid.Column="2" Text="Duration (days):" VerticalAlignment="Center" FontSize="12" Foreground="#64748B"/>
                            <TextBox Grid.Column="4" Text="{Binding DurationDays, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Days"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </Grid>
                        <Button Command="{Binding AddMedicineCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="42" HorizontalAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Margin="0,0,0,22">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ADD TO PRESCRIPTION" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Medicine List -->
                        <Border CornerRadius="12" Background="#F8FAFC" Padding="16" Margin="0,0,0,20">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasMedicines}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="PRESCRIPTION LIST" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding MedicineItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="8" Padding="12,8" Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="Bold" FontSize="13" Foreground="#1E293B">
                                                            <Run Text="{Binding MedicineName}"/>
                                                            <Run Text=" " />
                                                            <Run Text="{Binding Dosage}" Foreground="#64748B"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="11" Foreground="#94A3B8">
                                                            <Run Text="{Binding Frequency}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding DurationDays}"/>
                                                            <Run Text=" days"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Command="{Binding DataContext.RemoveMedicineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}"
                                                            Width="28" Height="28" Padding="0">
                                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#EF4444"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Notes -->
                        <TextBlock Text="PRESCRIPTION NOTES" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding PrescriptionNotes, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Additional notes or warnings for pharmacist..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                 Margin="0,0,0,20"/>

                        <!-- Status -->
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasStatusMsg}" Value="True"/>
                                                <Condition Binding="{Binding HasError}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#16A34A" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding StatusMsg}" Foreground="#16A34A" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasStatusMsg}" Value="True"/>
                                                <Condition Binding="{Binding HasError}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#DC2626" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding StatusMsg}" Foreground="#DC2626" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding SavePrescriptionCommand}"
                                Height="52" Background="#16A34A" BorderBrush="#16A34A"
                                Foreground="White" FontWeight="Black" FontSize="13"
                                materialDesign:ButtonAssist.CornerRadius="14"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSaveOutline" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="SAVE PRESCRIPTION" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
