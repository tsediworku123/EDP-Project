<Window x:Class="HMS.Core.Views.AddNewUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add New User" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Add New User" Style="{StaticResource MaterialDesignHeadline4TextBlock}" Margin="0,0,0,24"/>

            <ComboBox materialDesign:HintAssist.Hint="Role *" 
                      ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole}"
                      Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,8"/>

            <materialDesign:TransitioningContent OpeningEffect="{materialDesign:TransitionEffect FadeIn}">
                <ComboBox materialDesign:HintAssist.Hint="Link to Doctor *" 
                          ItemsSource="{Binding Doctors}"
                          SelectedItem="{Binding SelectedDoctor}"
                          DisplayMemberPath="FullName"
                          Visibility="{Binding IsDoctorRoleSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,8"/>
            </materialDesign:TransitioningContent>

            <TextBox materialDesign:HintAssist.Hint="Username *" 
                     Text="{Binding Username}" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>

            <PasswordBox materialDesign:HintAssist.Hint="Password *" 
                         x:Name="PassBox"
                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,8"/>

            <PasswordBox materialDesign:HintAssist.Hint="Confirm Password *" 
                         x:Name="ConfirmPassBox"
                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,8"/>

            <TextBox materialDesign:HintAssist.Hint="Email (Optional)" 
                     Text="{Binding Email}" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,8"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                <Button Style="{StaticResource MaterialDesignFlatButton}" Content="CANCEL" Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Content="CREATE USER" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
