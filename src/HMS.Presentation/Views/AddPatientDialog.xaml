<UserControl x:Class="HMS.Core.Views.AddPatientDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="600" Padding="30">
    <StackPanel>
        <TextBlock Text="{Binding DialogTitle}" Style="{DynamicResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" Margin="0,0,0,25" HorizontalAlignment="Center" Foreground="#1E293B"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Personal Info -->
            <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,15" materialDesign:HintAssist.Hint="Full Name" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />
            <DatePicker Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Date of Birth" SelectedDate="{Binding DateOfBirth}" Style="{DynamicResource MaterialDesignOutlinedDatePicker}" />

            <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,15" materialDesign:HintAssist.Hint="Gender" SelectedItem="{Binding Gender}" Style="{DynamicResource MaterialDesignOutlinedComboBox}">
                <ComboBoxItem Content="Male" />
                <ComboBoxItem Content="Female" />
                <ComboBoxItem Content="Other" />
            </ComboBox>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Phone Number" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />

            <ComboBox Grid.Row="2" Grid.Column="0" Margin="0,0,10,15" materialDesign:HintAssist.Hint="Blood Group" SelectedItem="{Binding BloodGroup}" Style="{DynamicResource MaterialDesignOutlinedComboBox}">
                <ComboBoxItem Content="A+" />
                <ComboBoxItem Content="A-" />
                <ComboBoxItem Content="B+" />
                <ComboBoxItem Content="B-" />
                <ComboBoxItem Content="AB+" />
                <ComboBoxItem Content="AB-" />
                <ComboBoxItem Content="O+" />
                <ComboBoxItem Content="O-" />
                <ComboBoxItem Content="Unknown" />
            </ComboBox>
            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Address" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />

            <!-- Contact Info -->
            <TextBox Grid.Row="3" Grid.Column="0" Margin="0,0,10,15" materialDesign:HintAssist.Hint="Emergency Contact Name" Text="{Binding EmergencyName, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />
            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Emergency Phone" Text="{Binding EmergencyPhone, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" />

            <TextBox Grid.Row="4" Grid.ColumnSpan="2" Margin="0,0,0,15" materialDesign:HintAssist.Hint="Medical Notes / History" Text="{Binding MedicalNotes}" Style="{DynamicResource MaterialDesignOutlinedTextBox}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="CANCEL" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Style="{DynamicResource MaterialDesignFlatButton}" Margin="0,0,10,0" Foreground="#64748B"/>
            <Button Content="{Binding ActionButtonText}" Command="{Binding SaveCommand}" Style="{DynamicResource MaterialDesignFlatMidPrimaryButton}" Background="#10B981" Width="180" />
        </StackPanel>
    </StackPanel>
</UserControl>
