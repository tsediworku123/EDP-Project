<UserControl x:Class="HMS.Core.Views.DoctorDiagnoseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             Background="#F8FAFC">

    <UserControl.Resources>
        <Style x:Key="ActionCardStyle" TargetType="materialDesign:Card">
            <Setter Property="UniformCornerRadius" Value="16"/>
            <Setter Property="Padding" Value="28"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="36,30,36,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="5" Height="32" Background="#D97706" CornerRadius="3" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="DIAGNOSE ILLNESSES" FontSize="26" FontWeight="Black" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Select a patient appointment and record clinical diagnoses with ICD codes." FontSize="13" Foreground="#64748B"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Appointment Selector -->
                <materialDesign:Card Grid.Column="0" Style="{StaticResource ActionCardStyle}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="TODAY'S APPOINTMENTS" FontSize="11" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,16"/>
                        <Border Background="#FEF3C7" CornerRadius="8" Padding="10,8" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarToday" Foreground="#D97706" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding TodayDateDisplay}" Foreground="#92400E" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ListBox ItemsSource="{Binding TodayAppointments}"
                                 SelectedItem="{Binding SelectedAppointment}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,12" CornerRadius="10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#FFFBEB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PatientName}" FontWeight="Bold" FontSize="13" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding Reason}" FontSize="11" Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,20">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoAppointments}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="CalendarBlank" Width="36" Height="36" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock Text="No appointments today" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Right: Diagnosis Form -->
                <materialDesign:Card Grid.Column="2" Style="{StaticResource ActionCardStyle}">
                    <Grid>
                        <!-- No selection placeholder -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="Stethoscope" Width="56" Height="56" Foreground="#D97706" HorizontalAlignment="Center" Opacity="0.4"/>
                            <TextBlock Text="Select an appointment to begin diagnosis" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        </StackPanel>

                        <!-- Diagnosis form -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- Patient header -->
                            <Border Background="#FFFBEB" CornerRadius="12" Padding="18,14" Margin="0,0,0,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="44" Height="44" Margin="0,0,14,0">
                                        <Ellipse.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#D97706" Offset="0"/>
                                                <GradientStop Color="#F59E0B" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <materialDesign:PackIcon Kind="Account" Width="24" Height="24" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedPatientName}" FontSize="16" FontWeight="Bold" Foreground="#92400E"/>
                                        <TextBlock Text="{Binding SelectedAppointmentInfo}" FontSize="12" Foreground="#B45309"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Chief Complaint -->
                            <TextBlock Text="CHIEF COMPLAINT" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding ChiefComplaint, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Describe the primary complaint..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,20"/>

                            <!-- Diagnosis -->
                            <TextBlock Text="CLINICAL DIAGNOSIS" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Diagnosis, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Enter primary diagnosis (e.g. Hypertension, Diabetes Type II)..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="90" AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,20"/>

                            <!-- Recommendation -->
                            <TextBlock Text="CLINICAL RECOMMENDATION" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Recommendation, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Recommended treatment plan or follow-up..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,20"/>

                            <!-- Notes -->
                            <TextBlock Text="CLINICAL NOTES" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding ClinicalNotes, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Additional observations, vitals, examination findings..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,24"/>

                            <!-- Status message -->
                            <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasStatusMsg}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Background" Value="#DCFCE7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#16A34A" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding StatusMsg}" Foreground="#16A34A" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Save button -->
                            <Button Command="{Binding SaveDiagnosisCommand}"
                                    Height="52" Background="#D97706" BorderBrush="#D97706"
                                    Foreground="White" FontWeight="Black" FontSize="13"
                                    materialDesign:ButtonAssist.CornerRadius="14"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="SAVE DIAGNOSIS" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
