<Window x:Class="HMS.Core.Views.PatientShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:HMS.Core.ViewModels"
        Title="ALPHA CLINIC | Patient Portal" Height="850" Width="1350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <!-- Smooth Sidebar Animation -->
        <Storyboard x:Key="ExpandSidebar">
            <DoubleAnimation Storyboard.TargetName="navColumn" Storyboard.TargetProperty="Width" To="240" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CollapseSidebar">
            <DoubleAnimation Storyboard.TargetName="navColumn" Storyboard.TargetProperty="Width" To="70" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Navigation Column (Compressed=70, Relaxed=240) -->
            <ColumnDefinition x:Name="navColumn">
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="240" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <Setter Property="Width" Value="70" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 1. LEFT NAVIGATION RAIL (ADMIN-STYLE SLATE 900) -->
        <materialDesign:Card Grid.Column="0" UniformCornerRadius="0" materialDesign:ElevationAssist.Elevation="Dp12" Background="#0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Logo/Close Toggle -->
                    <RowDefinition Height="*" />    <!-- Nav Items -->
                    <RowDefinition Height="Auto" /> <!-- Profile/Logout -->
                </Grid.RowDefinitions>

                <!-- Logo & Toggle Section -->
                <Grid Grid.Row="0" Margin="10,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /> <!-- Logo Area -->
                        <ColumnDefinition Width="Auto" /> <!-- Toggle Area -->
                    </Grid.ColumnDefinitions>

                    <!-- "ALPHA" BRANDING (hides on collapse via Trigger) -->
                    <StackPanel Grid.Column="0" Margin="10,0" VerticalAlignment="Center" x:Name="AlphaLogo">
                        <TextBlock Text="ALPHA" Foreground="White" FontSize="28" FontWeight="ExtraBold" />
                        <TextBlock Text="PATIENT PORTAL" Foreground="#3B82F6" FontSize="10" FontWeight="Bold" Margin="2,-4,0,0" />
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                    </StackPanel>

                    <!-- Hamburger / Toggle -->
                    <Button Grid.Column="1" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                            Width="50" Height="50" ToolTip="Toggle Sidebar">
                        <materialDesign:PackIcon Kind="Menu" Foreground="White" Width="28" Height="28" />
                    </Button>
                </Grid>

                <!-- Navigation List (Standard Buttons with Active Highlight Triggers) -->
                <StackPanel Grid.Row="1" Margin="0,20">
                    <Button Command="{Binding NavDashboardCommand}" Tag="DASHBOARD">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePageTitle}" Value="DASHBOARD">
                                        <Setter Property="Background" Value="#3B82F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="DASHBOARD" Foreground="White" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    
                    <Button Command="{Binding NavBookingCommand}" Tag="BOOK NEW VISIT">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePageTitle}" Value="BOOK NEW VISIT">
                                        <Setter Property="Background" Value="#3B82F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="BOOK NEW VISIT" Foreground="White" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <Button Command="{Binding NavAppointmentsCommand}" Tag="MY APPOINTMENTS">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePageTitle}" Value="MY APPOINTMENTS">
                                        <Setter Property="Background" Value="#3B82F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="MY APPOINTMENTS" Foreground="White" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <Button Command="{Binding NavHistoryCommand}" Tag="MEDICAL RECORDS">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePageTitle}" Value="MEDICAL RECORDS">
                                        <Setter Property="Background" Value="#3B82F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="MEDICAL RECORDS" Foreground="White" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <Button Command="{Binding NavProfileCommand}" Tag="MY PROFILE">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignNavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActivePageTitle}" Value="MY PROFILE">
                                        <Setter Property="Background" Value="#3B82F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="MY PROFILE" Foreground="White" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>

                <!-- Logout Bottom -->
                <Button Grid.Row="2" Command="{Binding LogoutCommand}" Style="{StaticResource MaterialDesignNavButton}" Tag="Logout" Margin="10,0,10,30">
                    <TextBlock Text="LOGOUT" Foreground="#EF5350" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Animation Triggers -->
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource CollapseSidebar}" />
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource ExpandSidebar}" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
            </Grid>
        </materialDesign:Card>

        <!-- 2. MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" /> <!-- Top Bar -->
                <RowDefinition Height="*" />  <!-- Page Content -->
            </Grid.RowDefinitions>

            <!-- Top Header (Draggable Title Bar) -->
            <materialDesign:Card Grid.Row="0" UniformCornerRadius="0" materialDesign:ElevationAssist.Elevation="Dp1" Background="White" MouseLeftButtonDown="DragWindow">
                <Grid Margin="40,0,10,0">
                    <TextBlock Text="{Binding ActivePageTitle}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                               FontWeight="ExtraBold" Foreground="#1E293B" VerticalAlignment="Center" />
                    
                    <!-- Right Actions & Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Notifications -->
                        <materialDesign:PackIcon Kind="BellOutline" Width="24" Height="24" Foreground="#1E293B" Opacity="0.5" Margin="0,0,15,0" VerticalAlignment="Center" />
                        
                        <!-- User Identity -->
                        <TextBlock Text="HELLO, PATIENT" Foreground="#1E293B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" />
                        
                        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0" Height="25" Margin="0,0,10,0" />

                        <!-- WINDOW MANAGEMENT BUTTONS -->
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Click="MinimizeWindow" Width="35" Height="35" Padding="0" ToolTip="Minimize">
                                <materialDesign:PackIcon Kind="WindowMinimize" Foreground="#1E293B" Width="18" Height="18" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Click="MaximizeWindow" Width="35" Height="35" Padding="0" ToolTip="Maximize">
                                <materialDesign:PackIcon Kind="WindowMaximize" Foreground="#1E293B" Width="18" Height="18" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Click="CloseWindow" Width="35" Height="35" Padding="0" ToolTip="Close">
                                <materialDesign:PackIcon Kind="Close" Foreground="#EF5350" Width="20" Height="20" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- Page Transition Host -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</Window>
