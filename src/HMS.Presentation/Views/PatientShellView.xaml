<Window x:Class="HMS.Core.Views.PatientShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:HMS.Core.ViewModels"
        Title="ALPHA CLINIC | Patient Portal" Height="850" Width="1350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
 
        <!-- Sidebar Navigation Button Style -->
        <Style x:Key="MaterialDesignNavButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="Background" Value="#1E293B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
 
        <!-- Sidebar Text Visibility Logic -->
        <Style x:Key="SidebarTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
 
        <!-- Smooth Sidebar Animation -->
        <Storyboard x:Key="ExpandSidebar">
            <DoubleAnimation Storyboard.TargetName="navColumn" Storyboard.TargetProperty="Width" To="240" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="CollapseSidebar">
            <DoubleAnimation Storyboard.TargetName="navColumn" Storyboard.TargetProperty="Width" To="70" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Navigation Column (Compressed=70, Relaxed=240) -->
            <ColumnDefinition x:Name="navColumn">
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="240" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <Setter Property="Width" Value="70" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 1. LEFT NAVIGATION RAIL (PREMIUM SLATE 900) -->
        <materialDesign:Card Grid.Column="0" UniformCornerRadius="0" materialDesign:ElevationAssist.Elevation="Dp12" Background="#0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Logo Section -->
                    <RowDefinition Height="*" />    <!-- Nav Items -->
                    <RowDefinition Height="Auto" /> <!-- User Profile Section -->
                </Grid.RowDefinitions>
 
                <!-- Logo & Toggle Section -->
                <Grid Grid.Row="0" Margin="15,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
 
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" x:Name="AlphaLogo">
                        <TextBlock Text="ALPHA" Foreground="White" FontSize="26" FontWeight="ExtraBold" />
                        <TextBlock Text="CLIENT PORTAL" Foreground="#60A5FA" FontSize="9" FontWeight="Black" Margin="2,-2,0,0" Opacity="0.9" />
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                    </StackPanel>
 
                    <Button Grid.Column="1" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                            Width="44" Height="44" materialDesign:ButtonAssist.CornerRadius="10">
                        <materialDesign:PackIcon Kind="Menu" Foreground="White" Width="24" Height="24" Opacity="0.8" />
                    </Button>
                </Grid>
 
                <!-- Navigation List -->
                <StackPanel Grid.Row="1" Margin="10,10">
                    <!-- Dashboard -->
                    <Button Command="{Binding NavDashboardCommand}" Style="{StaticResource MaterialDesignNavButton}" Tag="DASHBOARD" Margin="0,4">
                        <Grid HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" Margin="5,0,20,0" VerticalAlignment="Center"/>
                                <TextBlock Text="DASHBOARD" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SidebarTextStyle}"/>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="4" Height="24" Background="#3B82F6" HorizontalAlignment="Left" Margin="-15,0,0,0" CornerRadius="0,2,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePageTitle}" Value="DASHBOARD">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </Button>
 
                    <!-- Appointments -->
                    <Button Command="{Binding NavAppointmentsCommand}" Style="{StaticResource MaterialDesignNavButton}" Tag="MY APPOINTMENTS" Margin="0,4">
                        <Grid HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarClock" Width="22" Height="22" Margin="5,0,20,0" VerticalAlignment="Center"/>
                                <TextBlock Text="MY VISITS" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SidebarTextStyle}"/>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="4" Height="24" Background="#3B82F6" HorizontalAlignment="Left" Margin="-15,0,0,0" CornerRadius="0,2,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePageTitle}" Value="MY APPOINTMENTS">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </Button>
 
                    <!-- History -->
                    <Button Command="{Binding NavHistoryCommand}" Style="{StaticResource MaterialDesignNavButton}" Tag="MEDICAL RECORDS" Margin="0,4">
                        <Grid HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentMultiple" Width="22" Height="22" Margin="5,0,20,0" VerticalAlignment="Center"/>
                                <TextBlock Text="HEALTH RECORDS" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SidebarTextStyle}"/>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="4" Height="24" Background="#3B82F6" HorizontalAlignment="Left" Margin="-15,0,0,0" CornerRadius="0,2,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePageTitle}" Value="MEDICAL RECORDS">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </Button>
 
                    <!-- Profile -->
                    <Button Command="{Binding NavProfileCommand}" Style="{StaticResource MaterialDesignNavButton}" Tag="MY PROFILE" Margin="0,4">
                        <Grid HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountSettings" Width="22" Height="22" Margin="5,0,20,0" VerticalAlignment="Center"/>
                                <TextBlock Text="MY PROFILE" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SidebarTextStyle}"/>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="4" Height="24" Background="#3B82F6" HorizontalAlignment="Left" Margin="-15,0,0,0" CornerRadius="0,2,2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePageTitle}" Value="MY PROFILE">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </Button>
                </StackPanel>
 
                <!-- User Profile Section -->
                <StackPanel Grid.Row="2" Margin="10,0,10,20">
                    <Separator Margin="10,0,10,15" Opacity="0.1" Background="White"/>
                    
                    <Grid Margin="5,5,5,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <Border Width="40" Height="40" Background="#3B82F6" CornerRadius="20" HorizontalAlignment="Center">
                            <TextBlock Text="P" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                        </Border>
                        
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Client Account" Foreground="White" FontWeight="Bold" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SidebarTextStyle}"/>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Verified Member" Foreground="#60A5FA" FontSize="11" Opacity="0.8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SidebarTextStyle}"/>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
 
                    <Button Command="{Binding LogoutCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                            Foreground="#F87171" HorizontalContentAlignment="Left" Padding="10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="SIGN OUT" VerticalAlignment="Center" FontWeight="Bold" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SidebarTextStyle}"/>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
 
                <!-- Animation Triggers -->
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource CollapseSidebar}" />
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource ExpandSidebar}" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
            </Grid>
        </materialDesign:Card>

        <!-- 2. MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" /> <!-- Top Bar -->
                <RowDefinition Height="*" />  <!-- Page Content -->
            </Grid.RowDefinitions>

            <!-- Top Header (Draggable Title Bar) -->
            <materialDesign:Card Grid.Row="0" UniformCornerRadius="0" materialDesign:ElevationAssist.Elevation="Dp1" Background="White" MouseLeftButtonDown="DragWindow">
                <Grid Margin="40,0,10,0">
                    <TextBlock Text="{Binding ActivePageTitle}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                               FontWeight="ExtraBold" Foreground="#1E293B" VerticalAlignment="Center" />
                    
                    <!-- Right Actions & Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Notifications -->
                        <materialDesign:PackIcon Kind="BellOutline" Width="24" Height="24" Foreground="#1E293B" Opacity="0.5" Margin="0,0,15,0" VerticalAlignment="Center" />
                        
                        <!-- User Identity -->
                        <TextBlock Text="HELLO, PATIENT" Foreground="#1E293B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" />
                        
                        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1,0,0,0" Height="25" Margin="0,0,10,0" />

                        <!-- WINDOW MANAGEMENT BUTTONS -->
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Click="MinimizeWindow" Width="35" Height="35" Padding="0" ToolTip="Minimize">
                                <materialDesign:PackIcon Kind="WindowMinimize" Foreground="#1E293B" Width="18" Height="18" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Click="MaximizeWindow" Width="35" Height="35" Padding="0" ToolTip="Maximize">
                                <materialDesign:PackIcon Kind="WindowMaximize" Foreground="#1E293B" Width="18" Height="18" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Click="CloseWindow" Width="35" Height="35" Padding="0" ToolTip="Close">
                                <materialDesign:PackIcon Kind="Close" Foreground="#EF5350" Width="20" Height="20" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- Page Transition Host -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</Window>
