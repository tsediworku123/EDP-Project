<UserControl x:Class="HMS.Core.Views.DoctorDischargeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="DISCHARGE SUMMARIES" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="ExtraBold" Foreground="#000000" />
            <TextBlock Text="Finalize clinical records and instructions before closing outpatient visits." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Foreground="#6B7280" Margin="0,8,0,40" />

            <materialDesign:Card UniformCornerRadius="10" Padding="30" Width="600" HorizontalAlignment="Left" Background="#FEF2F2">
                <StackPanel>
                    <materialDesign:PackIcon Kind="FileDocumentEditOutline" Width="40" Height="40" Foreground="#DC2626" Margin="0,0,0,15"/>
                    <TextBlock Text="Discharge Summary Editor" FontWeight="Bold" FontSize="18" Foreground="#991B1B" />
                    <TextBlock Text="Export options to PDF and patient portal records live here." Foreground="#DC2626" Margin="0,10,0,0" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</UserControl>
