<UserControl x:Class="HMS.Core.Views.DoctorDischargeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:DoctorDischargeViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="36,30,36,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="5" Height="32" Background="#DC2626" CornerRadius="3" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="DISCHARGE SUMMARIES" FontSize="26" FontWeight="Black" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Finalize patient visits with discharge notes, follow-up instructions and condition status." FontSize="13" Foreground="#64748B"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Appointment selector (last 7 days) -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="16" Padding="22" materialDesign:ElevationAssist.Elevation="Dp2" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="RECENT APPOINTMENTS" FontSize="11" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,6"/>
                        <TextBlock Text="Last 7 days" FontSize="11" Foreground="#CBD5E1" Margin="0,0,0,14"/>
                        <ListBox ItemsSource="{Binding CompletedAppointments}"
                                 SelectedItem="{Binding SelectedAppointment}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,12" CornerRadius="10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PatientName}" FontWeight="Bold" FontSize="13" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding Reason}" FontSize="11" Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <StackPanel HorizontalAlignment="Center" Margin="0,14">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoAppointments}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="CalendarBlank" Width="32" Height="32" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock Text="No recent appointments" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Right: Discharge form -->
                <materialDesign:Card Grid.Column="2" UniformCornerRadius="16" Padding="28" materialDesign:ElevationAssist.Elevation="Dp2">

                    <!-- No selection -->
                    <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <materialDesign:PackIcon Kind="FileDocumentEditOutline" Width="56" Height="56" Foreground="#DC2626" HorizontalAlignment="Center" Opacity="0.4"/>
                        <TextBlock Text="Select an appointment to write discharge summary" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    </StackPanel>

                    <!-- Discharge form -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Patient header -->
                        <Border Background="#FEF2F2" CornerRadius="12" Padding="16,14" Margin="0,0,0,24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedPatientName}" FontSize="16" FontWeight="Bold" Foreground="#991B1B"/>
                                    <TextBlock Text="{Binding SelectedAppointmentInfo}" FontSize="12" Foreground="#DC2626"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#FECACA" CornerRadius="8" Padding="12,6" VerticalAlignment="Center">
                                    <TextBlock Text="DISCHARGE" FontSize="11" FontWeight="Black" Foreground="#DC2626"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Discharge condition -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DISCHARGE CONDITION" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding ConditionOptions}"
                                          SelectedItem="{Binding DischargeCondition}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          materialDesign:HintAssist.Hint="Patient condition at discharge"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DISCHARGE DATE" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="12,14" BorderBrush="#CBD5E1" BorderThickness="1">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1E293B">
                                        <Run Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='dd MMM yyyy', Mode=OneTime}" xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Discharge Summary -->
                        <TextBlock Text="DISCHARGE SUMMARY / DIAGNOSIS" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding DischargeSummary, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Summarize the patient's diagnosis and clinical course..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="100" AcceptsReturn="True" TextWrapping="Wrap"
                                 Margin="0,0,0,20"/>

                        <!-- Follow-up -->
                        <TextBlock Text="FOLLOW-UP INSTRUCTIONS" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding FollowUpInstructions, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="e.g. Return in 2 weeks, avoid strenuous activity..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                 Margin="0,0,0,20"/>

                        <!-- Prescription Summary -->
                        <TextBlock Text="DISCHARGE MEDICATIONS SUMMARY" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding PrescriptionSummary, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="List medications prescribed at discharge..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                 Margin="0,0,0,24"/>

                        <!-- Status banners -->
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasStatusMsg}" Value="True"/>
                                                <Condition Binding="{Binding HasError}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#16A34A" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding StatusMsg}" Foreground="#16A34A" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasStatusMsg}" Value="True"/>
                                                <Condition Binding="{Binding HasError}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#DC2626" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding StatusMsg}" Foreground="#DC2626" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding SaveDischargeCommand}"
                                Height="52" Background="#DC2626" BorderBrush="#DC2626"
                                Foreground="White" FontWeight="Black" FontSize="13"
                                materialDesign:ButtonAssist.CornerRadius="14"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentCheckOutline" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="SAVE DISCHARGE SUMMARY" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
