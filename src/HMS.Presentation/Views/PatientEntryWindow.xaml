<Window x:Class="HMS.Core.Views.PatientEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Patient Registration" Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{md:MaterialDesignFont}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="PATIENT REGISTRATION" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="Enter patient demographic and contact information" Foreground="Gray" FontSize="12"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-10,0" Padding="0,0,10,0">
            <StackPanel md:TextFieldAssist.HasClearButton="True">
                
                <GroupBox Header="Basic Information" md:ColorZoneAssist.Mode="PrimaryLight" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <TextBox md:HintAssist.Hint="Full Name (*)" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                        <DatePicker md:HintAssist.Hint="Date of Birth" SelectedDate="{Binding DateOfBirth}" Margin="0,5"/>
                        <ComboBox md:HintAssist.Hint="Gender" SelectedValue="{Binding Gender}" SelectedValuePath="Content" Margin="0,5">
                            <ComboBoxItem Content="Male"/>
                            <ComboBoxItem Content="Female"/>
                            <ComboBoxItem Content="Other"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Contact Details" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <TextBox md:HintAssist.Hint="Phone Number (*)" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                        <TextBox md:HintAssist.Hint="Email Address" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                        <TextBox md:HintAssist.Hint="Address" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Clinical Notes &amp; Allergies" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <TextBox md:HintAssist.Hint="Allergies / Chronic Conditions" 
                                 Text="{Binding Allergies, UpdateSourceTrigger=PropertyChanged}" 
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,5"/>
                        <TextBox md:HintAssist.Hint="Initial Medical Notes" 
                                 Text="{Binding MedicalNotes, UpdateSourceTrigger=PropertyChanged}" 
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Emergency Contact" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBox md:HintAssist.Hint="Contact Name" Text="{Binding EmergencyName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                        <TextBox md:HintAssist.Hint="Contact Phone" Text="{Binding EmergencyPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="CANCEL" Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0"/>
            <Button Content="SAVE PATIENT" Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="150"/>
        </StackPanel>
    </Grid>
</Window>
