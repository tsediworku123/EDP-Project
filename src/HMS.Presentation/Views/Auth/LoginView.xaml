<Window x:Class="HMS.Core.Views.Auth.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:HMS.Core.ViewModels.Auth"
        Title="Hospital Management System — Login"
        Height="600" Width="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <!-- Drop Shadow Border -->
    <Border CornerRadius="16"
            Background="#0F172A"
            Effect="{DynamicResource MaterialDesignShadowDepth5}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════ LEFT PANEL — Branding ══════════════ -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#00897B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Decorative circles -->
                    <Ellipse Width="250" Height="250" HorizontalAlignment="Left"
                             VerticalAlignment="Top" Margin="-80,-80,0,0"
                             Fill="White" Opacity="0.05"/>
                    <Ellipse Width="180" Height="180" HorizontalAlignment="Right"
                             VerticalAlignment="Bottom" Margin="0,0,-60,-60"
                             Fill="White" Opacity="0.07"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">

                        <!-- Hospital Icon -->
                        <Border Width="80" Height="80" CornerRadius="20"
                                Background="#FFFFFF22" HorizontalAlignment="Center"
                                Margin="0,0,0,24">
                            <materialDesign:PackIcon Kind="Hospital"
                                                     Width="44" Height="44"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="MediCare HMS"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe UI"/>

                        <TextBlock Text="Hospital Management System"
                                   FontSize="13" Foreground="#FFFFFFB0"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,32"
                                   FontFamily="Segoe UI"/>

                        <!-- Feature list -->
                        <StackPanel Margin="0,0,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#80FFD0"
                                                         Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Role-Based Access Control"
                                           Foreground="#E0F2F1" FontSize="13"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#80FFD0"
                                                         Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Appointment Management"
                                           Foreground="#E0F2F1" FontSize="13"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#80FFD0"
                                                         Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Medical Records &amp; History"
                                           Foreground="#E0F2F1" FontSize="13"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#80FFD0"
                                                         Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Doctor &amp; Patient Portals"
                                           Foreground="#E0F2F1" FontSize="13"
                                           Margin="10,0,0,0" VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="v1.0 · 2025"
                                   Foreground="#FFFFFF60" FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,40,0,0"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════ RIGHT PANEL — Login Form ══════════════ -->
            <Border Grid.Column="1" CornerRadius="0,16,16,0" Background="#0F172A">
                <Grid>
                    <!-- Drag handle (top bar) -->
                    <Border Height="40" VerticalAlignment="Top"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                            Cursor="SizeAll"/>

                    <!-- Close button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,8,12,0"
                            Width="32" Height="32"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Foreground="#94A3B8"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>

                    <!-- Form Content -->
                    <StackPanel VerticalAlignment="Center" Margin="52,0,52,0">

                        <TextBlock Text="Welcome Back"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="Sign in to your account to continue"
                                   FontSize="13" Foreground="#64748B"
                                   Margin="0,6,0,36"
                                   FontFamily="Segoe UI"/>

                        <!-- Username Field -->
                        <TextBlock Text="USERNAME" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#94A3B8" Margin="0,0,0,6"
                                   FontFamily="Segoe UI" />
                        <Border CornerRadius="10" Background="#1E293B" Margin="0,0,0,20" Height="50">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="AccountOutline"
                                                         Foreground="#3B82F6"
                                                         Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="UsernameBox"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         CaretBrush="White"
                                         FontSize="14"
                                         FontFamily="Segoe UI"
                                         VerticalAlignment="Center"
                                         Padding="0,0,12,0"
                                         Style="{StaticResource MaterialDesignTextBox}"/>
                            </Grid>
                        </Border>

                        <!-- Password Field -->
                        <TextBlock Text="PASSWORD" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#94A3B8" Margin="0,0,0,6"
                                   FontFamily="Segoe UI"/>
                        <Border CornerRadius="10" Background="#1E293B" Margin="0,0,0,8" Height="50">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="LockOutline"
                                                         Foreground="#3B82F6"
                                                         Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                <PasswordBox Grid.Column="1"
                                             x:Name="PasswordBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="White"
                                             CaretBrush="White"
                                             FontSize="14"
                                             FontFamily="Segoe UI"
                                             VerticalAlignment="Center"
                                             Padding="0,0,12,0"
                                             Style="{StaticResource MaterialDesignPasswordBox}"
                                             KeyDown="PasswordBox_KeyDown"/>
                            </Grid>
                        </Border>

                        <!-- Error Message -->
                        <Border CornerRadius="8" Background="#3F1010"
                                Padding="12,8" Margin="0,0,0,16"
                                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                         Foreground="#EF5350"
                                                         Width="16" Height="16"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#EF5350"
                                           FontSize="12" Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Loading Indicator -->
                        <ProgressBar IsIndeterminate="True" Height="2"
                                     Margin="0,0,0,16"
                                     Foreground="#3B82F6"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Login Button -->
                        <Button x:Name="LoginButton"
                                Height="52"
                                Click="LoginButton_Click"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#1565C0" Offset="0"/>
                                                <GradientStop Color="#00897B" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Login" Width="18" Height="18"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Sign In" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Hint -->
                        <TextBlock Margin="0,24,0,0"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe UI" FontSize="11">
                            <Run Foreground="#3B82F6" FontWeight="SemiBold" Text="admin"/>
                            <Run Foreground="#475569" Text=" / "/>
                            <Run Foreground="#3B82F6" FontWeight="SemiBold" Text="admin"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
