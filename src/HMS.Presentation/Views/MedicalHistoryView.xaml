<UserControl x:Class="HMS.Core.Views.MedicalHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HMS.Core.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1200"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.DataContext>
        <vm:MedicalHistoryViewModel />
    </UserControl.DataContext>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- Timeline -->
        </Grid.RowDefinitions>
 
        <!-- 1. HEADER SECTION -->
        <StackPanel Grid.Row="0" Margin="0,0,0,45">
            <TextBlock Text="MEDICAL HISTORY" 
                       Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                       FontWeight="Black" Foreground="#3B82F6" />
            <TextBlock Text="A chronological record of your clinical visits, diagnoses, and treatments." 
                       Style="{StaticResource MaterialDesignBody1TextBlock}" 
                       Opacity="0.5" Margin="0,8,0,0" />
        </StackPanel>
 
        <!-- 2. TIMELINE FEED -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Centralized Vertical Timeline Line -->
                <Border BorderBrush="#E2E8F0" BorderThickness="2,0,0,0" HorizontalAlignment="Left" Margin="14,0,0,0" />
                
                <ItemsControl ItemsSource="{Binding Records}" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
 
                                <!-- Timeline Bullet (Premium look) -->
                                <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15" 
                                        BorderBrush="White" BorderThickness="4" Background="#3B82F6" 
                                        VerticalAlignment="Top" Margin="0,15,0,0">
                                    <materialDesign:ElevationAssist.Elevation>Dp3</materialDesign:ElevationAssist.Elevation>
                                 </Border>
 
                                <!-- Content Card -->
                                <materialDesign:Card Grid.Column="1" UniformCornerRadius="24" Padding="35,25" 
                                                     materialDesign:ElevationAssist.Elevation="Dp2" Margin="30,0,50,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <materialDesign:PackIcon Kind="CalendarMonth" Foreground="#3B82F6" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Date, StringFormat='MMMM dd, yyyy'}" 
                                                           FontWeight="Bold" Foreground="#3B82F6" FontSize="13" VerticalAlignment="Center" />
                                            </StackPanel>
                                            
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                                                       FontWeight="Black" Foreground="#1E293B" Margin="0,0,0,10" />
                                            
                                            <TextBlock Text="{Binding Diagnosis}" FontWeight="SemiBold" Foreground="#64748B" FontSize="15" Margin="0,0,0,5" />
                                            
                                            <Border Background="#F8FAFC" CornerRadius="12" Padding="20,15" Margin="0,15,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="TREATMENT PLAN" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8" />
                                                    <TextBlock Text="{Binding Treatment}" Foreground="#475569" TextWrapping="Wrap" LineHeight="20" FontSize="14" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Top">
                                            <Border Width="60" Height="60" Background="#F1F5F9" CornerRadius="30">
                                                <materialDesign:PackIcon Kind="Doctor" Width="30" Height="30" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="Physician" HorizontalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding DoctorName}" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#1E293B" />
                                            
                                            <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                                                    Margin="0,25,0,0" Height="36" Padding="15,0" 
                                                    materialDesign:ButtonAssist.CornerRadius="10"
                                                    Content="DOWNLOAD" FontSize="11" FontWeight="Black" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
