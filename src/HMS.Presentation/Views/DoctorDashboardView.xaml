<UserControl x:Class="HMS.Core.Views.DoctorDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="DOCTOR DASHBOARD" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="#1E293B" />
            <TextBlock Text="Quick access to your daily schedule and patient records." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Opacity="0.6" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- Appointments List -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,20,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="UPCOMING APPOINTMENTS" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" FontWeight="Bold" Margin="0,0,0,20" />
                    <ItemsControl ItemsSource="{Binding TodayAppointments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="Clock" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,15,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding PatientName}" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Reason}" FontSize="12" Opacity="0.6" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Time}" FontWeight="Bold" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>

            <!-- Stats -->
            <StackPanel Grid.Column="1">
                <materialDesign:Card Style="{StaticResource PremiumCard}" Background="#E0F2FE" Margin="0,0,0,20">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="AccountStar" Foreground="#0284C7" Width="30" Height="30" />
                        <TextBlock Text="{Binding TotalPatientCount}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Margin="0,10,0,0" />
                        <TextBlock Text="Total Patients" Opacity="0.7" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Style="{StaticResource PremiumCard}" Background="#F0FDF4">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CalendarCheck" Foreground="#16A34A" Width="30" Height="30" />
                        <TextBlock Text="{Binding AppointmentsTodayCount}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Margin="0,10,0,0" />
                        <TextBlock Text="Appointments Today" Opacity="0.7" />
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
