<UserControl x:Class="HMS.Core.Views.DoctorAppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F1F5F9">

    <UserControl.Resources>
        <!-- Status badge color converter via triggers -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E2E8F0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ===== HEADER ===== -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,25">
            <StackPanel>
                <TextBlock Text="APPOINTMENTS" Style="{DynamicResource MaterialDesignHeadline5TextBlock}"
                           FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Manage and review your patient appointments." 
                           Style="{DynamicResource MaterialDesignSubtitle1TextBlock}" Opacity="0.6"/>
            </StackPanel>
            <Button Content="REFRESH" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MaterialDesignOutlinedButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Foreground="#64748B" BorderBrush="#CBD5E1"/>
        </Grid>

        <!-- ===== FILTERS ROW ===== -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status filter dropdown -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10,0"
                    materialDesign:ElevationAssist.Elevation="Dp1" MinWidth="180">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="FilterVariant" VerticalAlignment="Center" 
                                            Foreground="#64748B" Margin="0,0,8,0" Width="18" Height="18"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              materialDesign:HintAssist.Hint="Filter by Status"
                              materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                              BorderThickness="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Search box -->
            <Border Grid.Column="2" Background="White" CornerRadius="20" Padding="15,0"
                    materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="Search" VerticalAlignment="Center" 
                                            Foreground="#94A3B8" Width="18" Height="18"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                             BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0"
                             materialDesign:HintAssist.Hint="Search patient name or reason..."/>
                </Grid>
            </Border>

            <!-- Count badge -->
            <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="15,10"
                    materialDesign:ElevationAssist.Elevation="Dp1" HorizontalAlignment="Right" Margin="15,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CalendarRange" Foreground="#3B82F6" 
                                            Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Appointments:" Foreground="#64748B" FontSize="11"/>
                        <Run Text="{Binding AppointmentCount, Mode=OneWay}" FontWeight="Bold" FontSize="13"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== APPOINTMENTS TABLE ===== -->
        <materialDesign:Card Grid.Row="2" Grid.Column="0" UniformCornerRadius="15"
                             materialDesign:ElevationAssist.Elevation="Dp1" Margin="0,0,15,0">
            <DataGrid ItemsSource="{Binding Appointments}"
                      SelectedItem="{Binding SelectedAppointment, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" SelectionMode="Single"
                      Background="Transparent" BorderThickness="0"
                      HeadersVisibility="Column" GridLinesVisibility="None">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Height" Value="48"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="FontSize" Value="11"/>
                    </Style>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="Height" Value="62"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- ID -->
                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="55">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="15,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Patient -->
                    <DataGridTemplateColumn Header="PATIENT" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#DBEAFE" Margin="0,0,10,0">
                                        <materialDesign:PackIcon Kind="Account" Foreground="#3B82F6"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding PatientName}" VerticalAlignment="Center"
                                               FontWeight="SemiBold" Foreground="#1E293B"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date / Time -->
                    <DataGridTemplateColumn Header="DATE &amp; TIME" Width="155">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="5,0">
                                    <TextBlock Text="{Binding DateDisplay}" FontWeight="SemiBold" FontSize="13" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Reason -->
                    <DataGridTemplateColumn Header="REASON" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="5,0">
                                    <TextBlock Text="{Binding Reason}" Foreground="#334155" FontSize="13"/>
                                    <TextBlock Text="{Binding TypeDisplay}" FontSize="10" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Priority -->
                    <DataGridTemplateColumn Header="PRIORITY" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="Center" CornerRadius="4" Padding="8,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0FDF4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Priority}" Value="Urgent">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEmergency}" Value="True">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Priority}"/>
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Priority}" Value="Urgent">
                                                        <Setter Property="Foreground" Value="#D97706"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEmergency}" Value="True">
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                        <Setter Property="Text" Value="Emergency"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status -->
                    <DataGridTemplateColumn Header="STATUS" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="Center" CornerRadius="12" Padding="10,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Confirmed">
                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                    <Setter Property="Background" Value="#FEF9C3"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusBadge}" FontSize="11" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#64748B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Confirmed">
                                                        <Setter Property="Foreground" Value="#2563EB"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Foreground" Value="#CA8A04"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- ACTIONS column -->
                    <DataGridTemplateColumn Header="ACTIONS" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{DynamicResource MaterialDesignIconButton}"
                                            Width="32" Height="32" Padding="0" ToolTip="Edit Appointment"
                                            Command="{Binding DataContext.EditAppointmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="15" Height="15" Foreground="#3B82F6"/>
                                    </Button>
                                    <Button Style="{DynamicResource MaterialDesignIconButton}"
                                            Width="32" Height="32" Padding="0" ToolTip="Delete Appointment"
                                            Command="{Binding DataContext.DeleteAppointmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="15" Height="15" Foreground="#EF4444"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- ===== DETAIL SIDE PANEL ===== -->
        <materialDesign:Card Grid.Row="2" Grid.Column="1" UniformCornerRadius="15"
                             materialDesign:ElevationAssist.Elevation="Dp1" Width="330">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">

                    <!-- Panel Header -->
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="APPOINTMENT DETAIL" FontWeight="Bold" FontSize="13"
                                   Foreground="#1E293B" VerticalAlignment="Center"/>
                        <Button Command="{Binding ClearSelectionCommand}"
                                Style="{DynamicResource MaterialDesignIconButton}"
                                HorizontalAlignment="Right" Width="30" Height="30" Padding="0" ToolTip="Close">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="#94A3B8"/>
                        </Button>
                    </Grid>

                    <!-- Patient Info -->
                    <Border Background="#F8FAFC" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="42" Height="42" CornerRadius="21" Background="#DBEAFE" Margin="0,0,12,0">
                                    <materialDesign:PackIcon Kind="Account" Foreground="#3B82F6"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Width="22" Height="22"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedAppointment.PatientName}" FontWeight="Bold" FontSize="15" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding SelectedAppointment.TypeDisplay}" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <Separator Margin="0,5"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Date" FontSize="10" Foreground="#94A3B8" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedAppointment.DateDisplay}" FontSize="13" Foreground="#1E293B" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Time" FontSize="10" Foreground="#94A3B8" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedAppointment.TimeDisplay}" FontSize="13" Foreground="#1E293B" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Reason -->
                    <TextBlock Text="REASON" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding SelectedAppointment.Reason}" FontSize="13" Foreground="#334155" TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <!-- Diagnosis -->
                    <TextBlock Text="DIAGNOSIS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <TextBlock FontSize="13" Foreground="#334155" TextWrapping="Wrap" Margin="0,0,0,15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding SelectedAppointment.Diagnosis}"/>
                                <Setter Property="Foreground" Value="#334155"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAppointment.Diagnosis}" Value="{x:Null}">
                                        <Setter Property="Text" Value="Not yet diagnosed"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Prescription -->
                    <TextBlock Text="PRESCRIPTION" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <TextBlock FontSize="13" Foreground="#334155" TextWrapping="Wrap" Margin="0,0,0,15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding SelectedAppointment.Prescription}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAppointment.Prescription}" Value="{x:Null}">
                                        <Setter Property="Text" Value="None"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Consultation Note -->
                    <TextBlock Text="CONSULTATION NOTE" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <TextBlock FontSize="13" Foreground="#334155" TextWrapping="Wrap" Margin="0,0,0,15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding SelectedAppointment.ConsultationNote}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAppointment.ConsultationNote}" Value="">
                                        <Setter Property="Text" Value="No notes added"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Recommendation -->
                    <TextBlock Text="RECOMMENDATION" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,5"/>
                    <TextBlock FontSize="13" Foreground="#334155" TextWrapping="Wrap" Margin="0,0,0,20">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding SelectedAppointment.Recommendation}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAppointment.Recommendation}" Value="">
                                        <Setter Property="Text" Value="None"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Separator Margin="0,0,0,15"/>

                    <!-- UPDATE STATUS SECTION -->
                    <TextBlock Text="UPDATE STATUS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,10"/>
                    <UniformGrid Columns="2" Rows="2">
                        <Button Content="Confirmed" Margin="0,0,5,5" Height="36"
                                Command="{Binding UpdateStatusCommand}" CommandParameter="Confirmed"
                                Background="#DBEAFE" Foreground="#2563EB" BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8" FontWeight="Bold" FontSize="11"/>
                        <Button Content="Completed" Margin="5,0,0,5" Height="36"
                                Command="{Binding UpdateStatusCommand}" CommandParameter="Completed"
                                Background="#DCFCE7" Foreground="#16A34A" BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8" FontWeight="Bold" FontSize="11"/>
                        <Button Content="Pending" Margin="0,5,5,0" Height="36"
                                Command="{Binding UpdateStatusCommand}" CommandParameter="Pending"
                                Background="#FEF9C3" Foreground="#CA8A04" BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8" FontWeight="Bold" FontSize="11"/>
                        <Button Content="Cancelled" Margin="5,5,0,0" Height="36"
                                Command="{Binding UpdateStatusCommand}" CommandParameter="Cancelled"
                                Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="8" FontWeight="Bold" FontSize="11"/>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>

        <!-- Empty state panel shown when nothing is selected -->
        <Border Grid.Row="2" Grid.Column="1" Width="330" CornerRadius="15"
                Background="White" materialDesign:ElevationAssist.Elevation="Dp1">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="CalendarBlank" Width="48" Height="48"
                                         Foreground="#CBD5E1" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="Select an appointment" FontSize="14" Foreground="#94A3B8" 
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="to view its details here" FontSize="12" Foreground="#CBD5E1"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

