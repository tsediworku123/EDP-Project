<UserControl x:Class="HMS.Core.Views.DoctorLabTestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:DoctorLabTestsViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="36,30,36,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="5" Height="32" Background="#C026D3" CornerRadius="3" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="REQUEST LAB TESTS" FontSize="26" FontWeight="Black" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Order lab tests and imaging for your patients. Quick-add common test panels." FontSize="13" Foreground="#64748B"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Patient selector -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="16" Padding="22" materialDesign:ElevationAssist.Elevation="Dp2" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="SELECT PATIENT" FontSize="11" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,14"/>
                        <ListBox ItemsSource="{Binding TodayAppointments}"
                                 SelectedItem="{Binding SelectedAppointment}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,12" CornerRadius="10" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="#FDF4FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PatientName}" FontWeight="Bold" FontSize="13" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <StackPanel HorizontalAlignment="Center" Margin="0,12">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoAppointments}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="CalendarBlank" Width="32" Height="32" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock Text="No appointments today" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Right: Lab Order Builder -->
                <materialDesign:Card Grid.Column="2" UniformCornerRadius="16" Padding="28" materialDesign:ElevationAssist.Elevation="Dp2">

                    <Grid>
                    <!-- No selection placeholder -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <materialDesign:PackIcon Kind="FlaskEmptyOutline" Width="56" Height="56" Foreground="#C026D3" HorizontalAlignment="Center" Opacity="0.4"/>
                        <TextBlock Text="Select a patient to request lab tests" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    </StackPanel>

                    <!-- Lab Order Form -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Patient header -->
                        <Border Background="#FDF4FF" CornerRadius="12" Padding="16,12" Margin="0,0,0,22">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FlaskEmptyOutline" Width="22" Height="22" Foreground="#C026D3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedPatientName}" FontSize="15" FontWeight="Bold" Foreground="#701A75"/>
                                    <TextBlock Text="{Binding SelectedAppointmentInfo}" FontSize="11" Foreground="#C026D3"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Quick-add common tests -->
                        <TextBlock Text="QUICK-ADD COMMON TESTS" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <ItemsControl ItemsSource="{Binding CommonTests}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Command="{Binding DataContext.QuickAddTestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Height="32" Margin="0,0,6,6"
                                                materialDesign:ButtonAssist.CornerRadius="16"
                                                FontSize="11" FontWeight="Bold">
                                            <TextBlock Text="{Binding}"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>

                        <!-- Custom test add -->
                        <TextBlock Text="ADD CUSTOM TEST" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding TestName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Test name..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding TestCategories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Category"/>
                            <Button Grid.Column="4" Command="{Binding AddTestCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#C026D3" BorderBrush="#C026D3"
                                    Height="48" Padding="16,0"
                                    materialDesign:ButtonAssist.CornerRadius="10">
                                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Foreground="White"/>
                            </Button>
                        </Grid>

                        <!-- Order list -->
                        <Border CornerRadius="12" Background="#FDF4FF" Padding="16" Margin="0,0,0,20">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTests}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="LAB ORDER SUMMARY" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding RequestedTests}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="8" Padding="12,8" Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding TestName}" FontWeight="Bold" FontSize="13" Foreground="#1E293B" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" Background="#EDE9FE" CornerRadius="6" Padding="8,3" Margin="8,0">
                                                        <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="#7C3AED"/>
                                                    </Border>
                                                    <Button Grid.Column="2"
                                                            Command="{Binding DataContext.RemoveTestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}"
                                                            Width="28" Height="28" Padding="0">
                                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#EF4444"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Clinical notes -->
                        <TextBlock Text="CLINICAL NOTES FOR LAB" FontSize="10" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding ClinicalNotes, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Clinical context or special handling instructions..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                 Margin="0,0,0,20"/>

                        <!-- Status banners -->
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasStatusMsg}" Value="True"/>
                                                <Condition Binding="{Binding HasError}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="#16A34A" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding StatusMsg}" Foreground="#16A34A" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasStatusMsg}" Value="True"/>
                                                <Condition Binding="{Binding HasError}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#DC2626" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding StatusMsg}" Foreground="#DC2626" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding SubmitLabOrderCommand}"
                                Height="52" Background="#C026D3" BorderBrush="#C026D3"
                                Foreground="White" FontWeight="Black" FontSize="13"
                                materialDesign:ButtonAssist.CornerRadius="14"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FlaskOutline" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="SUBMIT LAB ORDER" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
