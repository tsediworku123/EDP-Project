<UserControl x:Class="HMS.Core.Views.PatientDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             Background="White"
             Foreground="{DynamicResource MaterialDesignBody}">

    <UserControl.Resources>
        <!-- Specialized Gradient for Hero Section (Slate to Blue) -->
        <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0" />
            <GradientStop Color="#3B82F6" Offset="1" />
        </LinearGradientBrush>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Greeting -->
                <RowDefinition Height="Auto" /> <!-- Hero / Next Visit -->
                <RowDefinition Height="Auto" /> <!-- Quick Actions -->
                <RowDefinition Height="Auto" /> <!-- Health & Activity -->
            </Grid.RowDefinitions>
 
            <!-- 1. GREETING & HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="{Binding WelcomeMessage}" 
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                           FontWeight="Black" Foreground="#3B82F6" />
                <TextBlock Text="Your health is in good hands. Stay updated with your latest clinic insights." 
                           Style="{StaticResource MaterialDesignBody1TextBlock}" 
                           Opacity="0.5" Margin="0,8,0,0" />
            </StackPanel>
 
            <!-- 2. HERO CARD (NEXT APPOINTMENT) -->
            <materialDesign:Card Grid.Row="1" UniformCornerRadius="24" Padding="0" Margin="0,0,0,30" 
                                  materialDesign:ElevationAssist.Elevation="Dp8" Background="{StaticResource HeroGradient}">
                <Grid Height="220">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <materialDesign:PackIcon Kind="CalendarStar" Grid.Column="1" Width="200" Height="200" 
                                              Foreground="White" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-30,-30" />
 
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="45,0">
                        <Border Background="White" CornerRadius="12" HorizontalAlignment="Left" Padding="14,6" Margin="0,0,0,20" Opacity="0.9">
                            <TextBlock Text="NEXT SCHEDULED VISIT" FontSize="10" Foreground="#3B82F6" FontWeight="Black"  />
                        </Border>
                        
                        <TextBlock Text="{Binding NextAppointment.AppointmentDate, StringFormat='dddd, MMMM dd | hh:mm tt', TargetNullValue='Time for a Checkup?', FallbackValue='Stay Proactive!'}" 
                                   Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                                   Foreground="White" FontWeight="Bold" />
                        
                        <TextBlock Text="{Binding NextAppointment.Reason, TargetNullValue='You don\'t have any upcoming visits. Keeping regular checkups is the best way to prevent issues.', FallbackValue='Your next health milestone is set.'}" 
                                   Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                   Foreground="White" Margin="0,12,0,0" Opacity="0.9" MaxWidth="500" TextWrapping="Wrap" />
                    </StackPanel>
 
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                                Background="White" Foreground="#3B82F6"
                                materialDesign:ButtonAssist.CornerRadius="15" 
                                Height="54" Padding="35,0" 
                                Command="{Binding DataContext.NavBookingCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Content="SCHEDULE VISIT" 
                                FontWeight="Black" FontSize="14" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
 
            <!-- 3. QUICK ACTIONS BAR -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,30">
                <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" Height="60" materialDesign:ButtonAssist.CornerRadius="16" Background="#EFF6FF">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarPlus" Foreground="#3B82F6" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Book Appointment" Foreground="#1E40AF" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="10,0" Height="60" materialDesign:ButtonAssist.CornerRadius="16" Background="#F0FDF4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileUpload" Foreground="#22C55E" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Upload Records" Foreground="#166534" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="10,0" Height="60" materialDesign:ButtonAssist.CornerRadius="16" Background="#FEF2F2">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CreditCard" Foreground="#EF4444" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Pay Invoices" Foreground="#991B1B" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="10,0,0,0" Height="60" materialDesign:ButtonAssist.CornerRadius="16" Background="#FAF5FF">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChatBubbleOutline" Foreground="#A855F7" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Message Clinic" Foreground="#6B21A8" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
 
            <!-- 4. HEALTH & ACTIVITY SECTION -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
 
                <!-- Left: Recent Activity -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="20" Padding="30" Margin="0,0,25,0">
                    <StackPanel>
                        <TextBlock Text="RECENT CLINICAL UPDATES" FontWeight="Black" FontSize="12" Foreground="#64748B" Margin="0,0,0,25" />
                        
                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <Border Width="44" Height="44" Background="#F1F5F9" CornerRadius="12">
                                                <materialDesign:PackIcon Kind="{Binding Icon}" Width="22" Height="22" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="#1E293B" />
                                                <TextBlock Text="{Binding Summary}" Opacity="0.5" FontSize="13" Margin="0,2,0,0" />
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="2" Text="{Binding Date, StringFormat='MMM dd'}" FontWeight="SemiBold" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>
 
                <!-- Right: Health Profile Summary & Tips -->
                <StackPanel Grid.Column="1">
                    <!-- Health Summary Card -->
                    <materialDesign:Card UniformCornerRadius="20" Padding="25" Margin="0,0,0,25" Background="#0F172A">
                        <StackPanel>
                            <TextBlock Text="HEALTH PROFILE SUMMARY" FontWeight="Black" FontSize="10" Foreground="#3B82F6" Margin="0,0,0,20" />
                            
                            <!-- Blood Group -->
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Blood Type" Foreground="White" Opacity="0.6"/>
                                <TextBlock Text="{Binding BloodGroup}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            
                            <!-- Allergies -->
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="Allergies" Foreground="White" Opacity="0.6"/>
                                <TextBlock Text="{Binding Allergies}" Foreground="#EF4444" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
 
                            <!-- Medications -->
                            <StackPanel>
                                <TextBlock Text="Current Medications" Foreground="White" Opacity="0.6"/>
                                <TextBlock Text="{Binding CurrentMedications}" Foreground="#10B981" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>
 
                    <!-- Seasonal Tip -->
                    <materialDesign:Card UniformCornerRadius="20" Padding="25" Background="#FEF3C7">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="LightbulbOn" Foreground="#D97706" Width="28" Height="28" Margin="0,0,0,15" />
                            <TextBlock Text="Weekly Health Tip" FontWeight="Black" FontSize="14" Foreground="#92400E" />
                            <TextBlock Text="In your last visit, consistent hydration was recommended. Try to drink at least 2 liters of water daily!" 
                                       Foreground="#B45309" Margin="0,10,0,0" TextWrapping="Wrap" LineHeight="20" />
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
