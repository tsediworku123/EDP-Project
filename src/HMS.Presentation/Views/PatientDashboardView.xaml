<UserControl x:Class="HMS.Core.Views.PatientDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             Background="White"
             Foreground="{DynamicResource MaterialDesignBody}">

    <UserControl.Resources>
        <!-- Specialized Gradient for Hero Section (Slate to Blue) -->
        <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0" />
            <GradientStop Color="#3B82F6" Offset="1" />
        </LinearGradientBrush>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Greeting -->
                <RowDefinition Height="Auto" /> <!-- Hero Section (Upcoming) -->
                <RowDefinition Height="Auto" /> <!-- Stats Section -->
                <RowDefinition Height="Auto" /> <!-- Activity & Details -->
            </Grid.RowDefinitions>

            <!-- 1. GREETING & HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,35">
                <TextBlock Text="{Binding WelcomeMessage}" 
                           Style="{StaticResource MaterialDesignHeadline3TextBlock}" 
                           FontWeight="Bold" Foreground="#1A237E" />
                <TextBlock Text="Managing your health is our priority. Explore your recent clinic updates below." 
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                           Opacity="0.6" Margin="0,10,0,0" />
            </StackPanel>

            <!-- 2. HERO CARD (NEXT APPOINTMENT) -->
            <materialDesign:Card Grid.Row="1" UniformCornerRadius="20" Padding="0" Margin="0,0,0,45" 
                                 materialDesign:ElevationAssist.Elevation="Dp6" Background="{StaticResource HeroGradient}"
                                 Cursor="Hand">
                <materialDesign:Card.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.NavBookingCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                </materialDesign:Card.InputBindings>
                <Grid Height="240">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Decorative Icon Background -->
                    <materialDesign:PackIcon Kind="CalendarStarOutline" Grid.Column="1" Width="200" Height="200" 
                                             Foreground="White" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-40,-40" />

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="50,0">
                        <Border Background="White" CornerRadius="12" HorizontalAlignment="Left" Padding="15,6" Margin="0,0,0,20" Opacity="0.9">
                            <TextBlock Text="NEXT CLINIC VISIT" Style="{StaticResource MaterialDesignOverlineTextBlock}" 
                                       Foreground="#3B82F6" FontWeight="Bold"  />
                        </Border>
                        
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockTimeEight" Width="42" Height="42" Foreground="White" 
                                                      VerticalAlignment="Center" Margin="0,0,20,0" />
                            <TextBlock Text="{Binding NextAppointment.AppointmentDate, StringFormat='dddd, MMMM dd | hh:mm tt', TargetNullValue='No Upcoming Visits Scheduled', FallbackValue='Stay proactive — book today!'}" 
                                       Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                                       Foreground="White" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <TextBlock Text="{Binding NextAppointment.Reason, TargetNullValue='Regular checkups are essential for long-term health and wellness.', FallbackValue='Manage your health—Explore our clinic services.'}" 
                                   Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                   Foreground="White" Margin="0,15,0,0" Opacity="1" FontWeight="SemiBold" MaxWidth="600" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Interactive Action Area -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                                Background="White" Foreground="#3B82F6"
                                materialDesign:ButtonAssist.CornerRadius="28" 
                                Height="56" Padding="40,0" 
                                Command="{Binding DataContext.NavBookingCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Content="+ BOOK NEW VISIT" 
                                FontWeight="Bold" FontSize="15" 
                                Cursor="Hand" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- 3. STAT TILES GRID -->
            <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,45">
                <!-- Visits Stat -->
                <materialDesign:Card Style="{StaticResource PremiumCard}" Margin="0,0,25,0" Background="#F1F5F9">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="ClipboardCheckOutline" Width="32" Height="32" Foreground="#3B82F6" />
                        <TextBlock Text="{Binding TotalVisits}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                                   FontWeight="Bold" Foreground="#1E293B" Margin="0,20,0,5" />
                        <TextBlock Text="Total Successful Visits" Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                   FontWeight="SemiBold" Opacity="0.5" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- Upcoming Stat -->
                <materialDesign:Card Style="{StaticResource PremiumCard}" Margin="12,0,12,0" Background="#F1F8E9">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CalendarClock" Width="32" Height="32" Foreground="#388E3C" />
                        <TextBlock Text="{Binding UpcomingCount}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                                   FontWeight="Bold" Foreground="#388E3C" Margin="0,20,0,5" />
                        <TextBlock Text="Upcoming Appointments" Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                   FontWeight="SemiBold" Opacity="0.5" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- Medical Records Stat -->
                <materialDesign:Card Style="{StaticResource PremiumCard}" Margin="25,0,0,0" Background="#ECEFF1">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="FileCabinet" Width="32" Height="32" Foreground="#455A64" />
                        <TextBlock Text="{Binding MedicalRecordsCount}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                                   FontWeight="Bold" Foreground="#455A64" Margin="0,20,0,5" />
                        <TextBlock Text="Available Medical Records" Style="{StaticResource MaterialDesignBody2TextBlock}" 
                                   FontWeight="SemiBold" Opacity="0.5" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- 4. LOWER CONTENT SECTION -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Recent Clinical Activity Feed -->
                <materialDesign:Card Grid.Column="0" UniformCornerRadius="15" Padding="40" 
                                     materialDesign:ElevationAssist.Elevation="Dp2" VerticalAlignment="Top" Margin="0,0,30,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,30">
                            <TextBlock Text="RECENT CLINICAL ACTIVITY" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                                       FontWeight="Bold" Opacity="0.5"  VerticalAlignment="Center" />
                            <Button Content="VIEW ALL HISTORY" Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding DataContext.NavHistoryCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    Foreground="#3B82F6" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,-10,-10,-10" />
                        </Grid>
                        
                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="0,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <materialDesign:PackIcon Kind="{Binding Icon}" Width="28" Height="28" 
                                                                     Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,30,0" Opacity="0.8" />
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="#37474F" />
                                                <TextBlock Text="{Binding Summary}" Opacity="0.6" Margin="0,6,0,0" FontSize="14" LineHeight="20" />
                                            </StackPanel>
                                            
                                            <Border Grid.Column="2" Background="#F5F5F5" CornerRadius="8" Padding="12,6" VerticalAlignment="Center" Margin="20,0,0,0">
                                                <TextBlock Text="{Binding Date, StringFormat='dd MMM yyyy'}" 
                                                           Style="{StaticResource MaterialDesignOverlineTextBlock}" FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Health Tips / Quick Info Support -->
                <StackPanel Grid.Column="1">
                    <materialDesign:Card UniformCornerRadius="15" Padding="30" Background="#F0F4C3" materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="LightbulbOnOutline" Width="28" Height="28" Foreground="#827717" Margin="0,0,0,15" />
                            <TextBlock Text="Stay Healthy!" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                       FontWeight="Bold" Foreground="#827717" />
                            <TextBlock Text="Drinking water regularly and getting 8 hours of sleep can significantly improve your immune system." 
                                       Margin="0,10,0,0" Opacity="0.75" TextWrapping="Wrap" />
                        </StackPanel>
                    </materialDesign:Card>
                    
                    <materialDesign:Card UniformCornerRadius="15" Padding="30" Margin="0,25,0,0" Background="#FFEBEE" materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="ShieldCheck" Width="28" Height="28" Foreground="#C62828" Margin="0,0,0,15" />
                            <TextBlock Text="Safety First" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" 
                                       FontWeight="Bold" Foreground="#C62828" />
                            <TextBlock Text="Always bring your personal ID and medical cards when visiting the clinic for a seamless experience." 
                                       Margin="0,10,0,0" Opacity="0.75" TextWrapping="Wrap" />
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
