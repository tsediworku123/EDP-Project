<UserControl x:Class="HMS.Core.Views.MyProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="950" d:DesignWidth="1200"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:PatientProfileViewModel />
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="*" />    <!-- Content -->
            </Grid.RowDefinitions>
 
            <!-- 1. HEADER -->
            <StackPanel Grid.Row="0" Margin="0,0,0,40">
                <TextBlock Text="PERSONAL CARE PROFILE" 
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                           FontWeight="Black" Foreground="#3B82F6" />
                <TextBlock Text="Manage your identity, communications, and emergency care preferences." 
                           Style="{StaticResource MaterialDesignBody1TextBlock}" 
                           Opacity="0.5" Margin="0,8,0,0" />
            </StackPanel>
 
            <!-- 2. GRID CONTENT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
 
                <!-- Left: Identity & Contact -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <materialDesign:Card UniformCornerRadius="24" Padding="35" materialDesign:ElevationAssist.Elevation="Dp2" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text="IDENTITY &amp; ADDRESS" FontWeight="Black" FontSize="12" Foreground="#64748B" Margin="0,0,0,25" />
                            
                            <Grid Margin="0,0,0,20">
                                <materialDesign:PackIcon Kind="AccountBox" Foreground="#3B82F6" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Patient.FullName}" materialDesign:HintAssist.Hint="Full Name" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="35,0,0,0" FontSize="14" />
                            </Grid>
 
                            <Grid Margin="0,0,0,20">
                                <materialDesign:PackIcon Kind="Calendar" Foreground="#3B82F6" Width="20" Height="20" VerticalAlignment="Center"/>
                                <DatePicker SelectedDate="{Binding Patient.DateOfBirth}" materialDesign:HintAssist.Hint="Birth Date" 
                                            Margin="35,0,0,0" FontSize="14" BorderThickness="0,0,0,1" />
                            </Grid>
 
                            <Grid Margin="0,0,0,20">
                                <materialDesign:PackIcon Kind="MapMarker" Foreground="#3B82F6" Width="20" Height="20" VerticalAlignment="Top" Margin="0,8,0,0"/>
                                <TextBox Text="{Binding Patient.Address}" materialDesign:HintAssist.Hint="Residential Address" 
                                         AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="35,0,0,0" FontSize="14" />
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
 
                    <materialDesign:Card UniformCornerRadius="24" Padding="35" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <TextBlock Text="COMMUNICATION" FontWeight="Black" FontSize="12" Foreground="#64748B" Margin="0,0,0,25" />
                            <Grid Margin="0,0,0,20">
                                <materialDesign:PackIcon Kind="Phone" Foreground="#10B981" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Patient.Phone}" materialDesign:HintAssist.Hint="Mobile Number" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="35,0,0,0" FontSize="14" />
                            </Grid>
                            <Grid>
                                <materialDesign:PackIcon Kind="Email" Foreground="#3B82F6" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Patient.Email}" materialDesign:HintAssist.Hint="Email Address" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="35,0,0,0" FontSize="14" />
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
 
                <!-- Right: Emergency & Health -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <materialDesign:Card UniformCornerRadius="24" Padding="35" materialDesign:ElevationAssist.Elevation="Dp2" Background="#FFF1F2" Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text="EMERGENCY CARE CONTACT" FontWeight="Black" FontSize="12" Foreground="#E11D48" Margin="0,0,0,25" />
                            <Grid Margin="0,0,0,20">
                                <materialDesign:PackIcon Kind="AccountAlert" Foreground="#E11D48" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Patient.EmergencyContactName}" materialDesign:HintAssist.Hint="Primary ICE Contact" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="35,0,0,0" FontSize="14" Foreground="#1E293B" />
                            </Grid>
                            <Grid>
                                <materialDesign:PackIcon Kind="PhoneForward" Foreground="#E11D48" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Patient.EmergencyContactPhone}" materialDesign:HintAssist.Hint="ICE Phone Number" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="35,0,0,0" FontSize="14" Foreground="#1E293B" />
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
 
                    <materialDesign:Card UniformCornerRadius="24" Padding="35" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <TextBlock Text="HEALTH NOTES &amp; CONDITIONS" FontWeight="Black" FontSize="12" Foreground="#64748B" Margin="0,0,0,25" />
                            <TextBox Text="{Binding Patient.AllergiesOrChronicConditions}" 
                                     materialDesign:HintAssist.Hint="Chronic Conditions or Allergies" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     Height="100" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,20" />
                            <TextBox Text="{Binding Patient.MedicalNotes}" 
                                     materialDesign:HintAssist.Hint="Self-Reported Health Notes" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     Height="150" AcceptsReturn="True" TextWrapping="Wrap" />
                        </StackPanel>
                    </materialDesign:Card>
 
                    <Button Command="{Binding UpdateCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                            Height="60" Margin="0,30,0,0" Background="#0F172A" BorderBrush="#0F172A"
                            materialDesign:ButtonAssist.CornerRadius="16" FontWeight="Black" FontSize="14">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Check" Width="22" Height="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="SAVE PROFILE CHANGES" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
