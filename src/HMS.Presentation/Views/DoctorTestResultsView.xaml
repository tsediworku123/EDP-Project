<UserControl x:Class="HMS.Core.Views.DoctorTestResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="VIEW TEST RESULTS" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="ExtraBold" Foreground="#000000" />
            <TextBlock Text="Review pending and completed lab and imaging reports." Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Foreground="#6B7280" Margin="0,8,0,40" />

            <materialDesign:Card UniformCornerRadius="10" Padding="30" Width="600" HorizontalAlignment="Left" Background="#F0F9FF">
                <StackPanel>
                    <materialDesign:PackIcon Kind="TextBoxSearchOutline" Width="40" Height="40" Foreground="#0284C7" Margin="0,0,0,15"/>
                    <TextBlock Text="Results Review Module" FontWeight="Bold" FontSize="18" Foreground="#075985" />
                    <TextBlock Text="Integration with pathology and radiology systems accessed here." Foreground="#0284C7" Margin="0,10,0,0" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</UserControl>
