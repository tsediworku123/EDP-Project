<UserControl x:Class="HMS.Core.Views.DoctorTestResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HMS.Core.ViewModels"
             Background="#F8FAFC">

    <UserControl.DataContext>
        <vm:DoctorTestResultsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="36,30,36,36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,28">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Border Width="5" Height="32" Background="#0284C7" CornerRadius="3" Margin="0,0,14,0" VerticalAlignment="Center"/>
                <TextBlock Text="VIEW TEST RESULTS" FontSize="26" FontWeight="Black" Foreground="#1E293B" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Review all lab test orders and results for your patients." FontSize="13" Foreground="#64748B"/>
        </StackPanel>

        <!-- Stats row -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" UniformCornerRadius="14" Padding="20" materialDesign:ElevationAssist.Elevation="Dp2" Background="#F0F9FF">
                <StackPanel>
                    <materialDesign:PackIcon Kind="FlaskOutline" Foreground="#0284C7" Width="24" Height="24" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="Black" Foreground="#0C4A6E"/>
                    <TextBlock Text="Total Ordered" FontSize="11" Foreground="#64748B"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" UniformCornerRadius="14" Padding="20" materialDesign:ElevationAssist.Elevation="Dp2" Background="#F0FDF4">
                <StackPanel>
                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#16A34A" Width="24" Height="24" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="28" FontWeight="Black" Foreground="#14532D"/>
                    <TextBlock Text="Completed" FontSize="11" Foreground="#64748B"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="4" UniformCornerRadius="14" Padding="20" materialDesign:ElevationAssist.Elevation="Dp2" Background="#FEF9C3">
                <StackPanel>
                    <materialDesign:PackIcon Kind="ClockOutline" Foreground="#CA8A04" Width="24" Height="24" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding PendingCount}" FontSize="28" FontWeight="Black" Foreground="#713F12"/>
                    <TextBlock Text="Pending" FontSize="11" Foreground="#64748B"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Filter row -->
        <Grid Grid.Row="2" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp1" Padding="14,0">
                <Grid>
                    <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center" Foreground="#94A3B8" Width="18" Height="18"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Search patient or test name..."
                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                             BorderThickness="0" Margin="28,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ComboBox Grid.Column="2" ItemsSource="{Binding StatusFilters}"
                      SelectedItem="{Binding FilterStatus}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="Filter by status"/>

            <Button Grid.Column="4" Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="48" Padding="20,0"
                    materialDesign:ButtonAssist.CornerRadius="10">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="REFRESH" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Results table -->
        <materialDesign:Card Grid.Row="3" UniformCornerRadius="16" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoResults}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="FlaskEmpty" Width="52" Height="52" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                    <TextBlock Text="No test results found" FontSize="15" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding FilteredResults}"
                          SelectedItem="{Binding SelectedResult}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" SelectionMode="Single"
                          Background="Transparent" BorderThickness="0"
                          HeadersVisibility="Column" GridLinesVisibility="None">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasNoResults}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Height" Value="46"/>
                            <Setter Property="Padding" Value="14,0"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Setter Property="Height" Value="58"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="PATIENT" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PatientName}" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center" Margin="14,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="TEST NAME" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Source.TestName}" Foreground="#334155" VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="CATEGORY" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#EDE9FE" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="4,0">
                                        <TextBlock Text="{Binding Source.TestCategory}" FontSize="11" FontWeight="Bold" Foreground="#7C3AED"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="REQUESTED" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RequestedDateDisplay}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="COMPLETED" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CompletedDateDisplay}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="STATUS" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="10,4" HorizontalAlignment="Center" Margin="4,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Source.Status}" Value="Completed">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Source.Status}" Value="In Progress">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Source.Status}" Value="Requested">
                                                        <Setter Property="Background" Value="#FEF9C3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Source.Status}" Value="Cancelled">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Source.Status}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Source.Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Source.Status}" Value="In Progress">
                                                            <Setter Property="Foreground" Value="#2563EB"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Source.Status}" Value="Requested">
                                                            <Setter Property="Foreground" Value="#CA8A04"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Source.Status}" Value="Cancelled">
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ACTION" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Height="30" FontSize="10" FontWeight="Bold"
                                            Command="{Binding DataContext.MarkCompletedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            materialDesign:ButtonAssist.CornerRadius="8"
                                            Margin="4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Source.Status}" Value="Completed">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Source.Status}" Value="Cancelled">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="Mark Done"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
